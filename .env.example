# Worker URL (local dev or production)
PUBLIC_WORKER_URL=http://localhost:8787
PUBLIC_ADMIN_TOKEN=change-me-in-production

# Payload backend
CMS_URL=http://localhost:3001

# Multi-tenant: pin this deploy to one tenant by slug (single-tenant deploy / local dev).
# Leave unset to resolve the tenant per-request from the request host (its `domains` list).
TENANT_SLUG=damietta-general-hospital

# For sync script
WORKER_URL=http://localhost:8787
ADMIN_TOKEN=change-me-in-production

# --- Commerce gateway (Astro signs storefront->CMS requests, plan §4.1) ---
# Astro signs with the CURRENT key only; the CMS verifies current + optional previous (rotation).
# Secret is base64 of >=32 random bytes (`openssl rand -base64 48`). Must match the CMS
# COMMERCE_GATEWAY_KEY_ID / COMMERCE_GATEWAY_SECRET. Must NOT reuse PAYLOAD_SECRET or provider secrets.
COMMERCE_GATEWAY_KEY_ID=
COMMERCE_GATEWAY_SECRET=
