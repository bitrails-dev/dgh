---
import CardBase from './CardBase.astro';

const { item, lang, categoryLabel, readLabel } = Astro.props;
const title = lang === 'ar' ? item.data.titleAr : item.data.title;
const summary = lang === 'ar' ? (item.data.summaryAr ?? '') : (item.data.summary ?? '');
const href = `/${lang}/events/${item.id}`;
const hasThumbnail = item.data.thumbnail && !item.data.thumbnail.includes('picsum');

const categoryColors: Record<string, string> = {
  procedure: 'bg-teal-700/10 text-teal-700',
  event: 'bg-navy-900/10 text-navy-900',
  announcement: 'bg-gold/15 text-gold',
};

const dateStr = item.data.date
  ? new Date(item.data.date).toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US', {
      year: 'numeric', month: 'short', day: 'numeric',
    })
  : '';

const badges = categoryLabel
  ? [{ label: categoryLabel, color: categoryColors[item.data.category] ?? 'bg-ink-500/10 text-ink-500' }]
  : [];
---

<CardBase
  href={href}
  image={hasThumbnail ? item.data.thumbnail : undefined}
  imageAlt={title}
  date={dateStr}
  title={title}
  description={summary || undefined}
  ctaLabel={readLabel}
  badges={badges}
/>
