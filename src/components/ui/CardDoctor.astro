---
const { doctor, lang, certifiedLabel, profileLabel, imageAlt } = Astro.props;
const name = lang === "ar" ? doctor.data.nameAr : doctor.data.name;
const specialty = lang === "ar" ? doctor.data.specialtyAr : doctor.data.specialty;
const href = `/${lang}/doctors/${doctor.id}`;
---
<article class="group flex flex-col sm:flex-row overflow-hidden rounded-2xl bg-surface shadow-soft transition-all duration-300 hover:shadow-deep">
  <!-- Image: full height on desktop, tall crop on mobile -->
  <a href={href} class="relative block shrink-0 sm:w-44 md:w-52 overflow-hidden">
    <img
      src={doctor.data.photo}
      alt={imageAlt ?? name}
      class="h-64 sm:h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    {doctor.data.certified && (
      <span class="absolute top-3 start-3 inline-flex items-center gap-1 rounded-full bg-accent/90 px-2.5 py-1 text-xs font-semibold text-white backdrop-blur-sm">
        <svg viewBox="0 0 24 24" class="h-3 w-3 fill-white" aria-hidden="true">
          <path d="M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z"/>
        </svg>
        {certifiedLabel}
      </span>
    )}
  </a>

  <!-- Content -->
  <div class="flex flex-1 flex-col justify-center p-5 text-center sm:text-start">
    <h3 class="text-lg font-bold text-text leading-snug">{name}</h3>
    <p class="mt-1 text-sm font-medium text-secondary">{specialty}</p>
    <a
      href={href}
      class="mt-4 inline-flex items-center justify-center sm:justify-start gap-1.5 text-sm font-semibold text-primary hover:gap-3 transition-all"
    >
      {profileLabel}
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  </div>
</article>
