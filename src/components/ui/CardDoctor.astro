---
import CardBase from './CardBase.astro';

const { doctor, lang, certifiedLabel, profileLabel, imageAlt } = Astro.props;
const name = lang === 'ar' ? doctor.data.nameAr : doctor.data.name;
const specialty = lang === 'ar' ? doctor.data.specialtyAr : doctor.data.specialty;
const href = `/${lang}/doctors/${doctor.id}`;

const imageBadge = doctor.data.certified
  ? {
      label: certifiedLabel,
      iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    }
  : undefined;
---

<CardBase
  href={href}
  image={doctor.data.photo}
  imageAlt={imageAlt ?? name}
  title={name}
  description={specialty}
  ctaLabel={profileLabel}
  imageBadge={imageBadge}
  horizontal={true}
/>
