---
import YouTubeEmbed from './YouTubeEmbed.astro';
import type { ArticleBlock } from '../../lib/blocks';

interface Props {
  blocks: ArticleBlock[];
  lang: 'ar' | 'en';
}
const { blocks, lang } = Astro.props;
const ar = lang === 'ar';
---
<div class="space-y-8">
  {blocks.map((block) => {
    switch (block.type) {
      case 'richText': {
        const html = (ar ? block.htmlAr : block.html) || block.html;
        return html && (
          <div class="bg-ivory-50 p-8 border border-ink-100">
            <div class="prose max-w-none" set:html={html} />
          </div>
        );
      }
      case 'heading': {
        const text = (ar ? block.textAr : block.text) || block.text;
        const Tag = block.level === 'h3' ? 'h3' : 'h2';
        return text && (
          <Tag class={`font-display-ar font-bold text-navy-900 ${block.level === 'h3' ? 'text-xl' : 'text-2xl'}`}>{text}</Tag>
        );
      }
      case 'image': {
        const alt = (ar ? block.altAr : block.alt) || block.alt;
        const caption = ar ? block.captionAr : block.caption;
        return block.url && (
          <figure class="space-y-2">
            <div class="overflow-hidden border border-ink-100">
              <img src={block.url} alt={alt} class="w-full object-cover" loading="lazy" />
            </div>
            {caption && <figcaption class="text-sm text-ink-400">{caption}</figcaption>}
          </figure>
        );
      }
      case 'youtube': {
        const caption = ar ? block.captionAr : block.caption;
        return (
          <figure class="space-y-2">
            <div class="overflow-hidden border border-ink-100">
              <YouTubeEmbed url={block.url} />
            </div>
            {caption && <figcaption class="text-sm text-ink-400">{caption}</figcaption>}
          </figure>
        );
      }
      case 'testimonial': {
        const text = (ar ? block.textAr : block.text) || block.text;
        const caption = ar ? block.captionAr : block.caption;
        return text && (
          <blockquote class="bg-teal-800 p-8 text-ivory-50 shadow-deep">
            <div class="flex items-start gap-4">
              {block.url && (
                <img src={block.url} alt={caption || ''} width="56" height="56" class="h-14 w-14 flex-shrink-0 rounded-full object-cover" loading="lazy" />
              )}
              <div>
                <p class="text-lg leading-relaxed">{text}</p>
                {caption && <footer class="mt-3 text-sm font-semibold text-ivory-100/70">{caption}</footer>}
              </div>
            </div>
          </blockquote>
        );
      }
    }
  })}
</div>
