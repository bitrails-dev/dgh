---
interface Badge {
  label: string;
  iconPath?: string;
  color?: string;
}

interface Props {
  href?: string;
  image?: string;
  imageAlt?: string;
  iconPath?: string;
  iconColor?: string;
  date?: string;
  preTitle?: string;
  title: string;
  description?: string;
  ctaLabel?: string;
  badges?: Badge[];
  imageBadge?: Badge;
  imageHeight?: string;
  horizontal?: boolean;
  class?: string;
}

const {
  href,
  image,
  imageAlt,
  iconPath,
  iconColor = 'text-teal-700',
  date,
  preTitle,
  title,
  description,
  ctaLabel,
  badges = [],
  imageBadge,
  imageHeight = 'h-44',
  horizontal = false,
  class: className = '',
} = Astro.props;

const hasImage = !!image;
---

{horizontal && (
  <article class={`group flex flex-col sm:flex-row bg-ivory-50 overflow-hidden border border-ink-100 transition-colors duration-200 hover:bg-white ${className}`}>
    {hasImage && (
      <div class="relative shrink-0 sm:w-44 md:w-52 overflow-hidden">
        <img
          src={image}
          alt={imageAlt ?? title}
          class="h-64 sm:h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        {imageBadge && (
          <span class={`absolute top-3 start-3 inline-flex items-center gap-1.5 rounded-full bg-white px-2.5 py-1 text-xs font-semibold text-navy-900 ${imageBadge.color ?? ''}`}>
            {imageBadge.iconPath && (
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-teal-700" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={imageBadge.iconPath} />
              </svg>
            )}
            {imageBadge.label}
          </span>
        )}
      </div>
    )}
    <div class="flex flex-1 flex-col justify-center p-5 text-center sm:text-start">
      {badges.map((badge) => (
        <span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold mb-2 w-fit ${badge.color ?? 'bg-ink-100 text-ink-700'}`}>
          {badge.iconPath && (
            <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={badge.iconPath} />
            </svg>
          )}
          {badge.label}
        </span>
      ))}
      {preTitle && <p class="text-xs font-semibold uppercase tracking-widest text-teal-700 mb-1">{preTitle}</p>}
      <h3 class="text-lg font-bold text-ink-900 leading-snug">{title}</h3>
      {description && <p class="mt-1 text-sm font-medium text-teal-700">{description}</p>}
      {ctaLabel && href && (
        <a href={href} class="mt-4 inline-block btn-text text-sm">{ctaLabel}</a>
      )}
    </div>
  </article>
)}

{!horizontal && (
  <article class={`group flex flex-col overflow-hidden border border-ink-100 transition-colors duration-200 ${className}`}>
    {hasImage && (
      <div class={`relative overflow-hidden ${imageHeight} shrink-0 bg-gradient-to-br from-navy-900/80 to-teal-700/80`}>
        <img
          src={image}
          alt={imageAlt ?? title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        {imageBadge && (
          <span class={`absolute top-3 start-3 inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold ${imageBadge.color ?? 'bg-white text-ink-900'}`}>
            {imageBadge.iconPath && (
              <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={imageBadge.iconPath} />
              </svg>
            )}
            {imageBadge.label}
          </span>
        )}
      </div>
    )}

    <div class="flex flex-1 flex-col p-5 bg-ivory-50 group-hover:bg-white transition-colors duration-200">
      {!hasImage && (iconPath || imageBadge) && (
        <div class="flex items-center justify-between mb-4">
          {iconPath && (
            <svg viewBox="0 0 24 24" class={`h-9 w-9 ${iconColor}`} fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={iconPath} />
            </svg>
          )}
          {imageBadge && (
            <span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold ${imageBadge.color ?? 'bg-ink-100 text-ink-700'}`}>
              {imageBadge.iconPath && (
                <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={imageBadge.iconPath} />
                </svg>
              )}
              {imageBadge.label}
            </span>
          )}
        </div>
      )}

      {!hasImage && !iconPath && !imageBadge && (
        <div class="mb-4">
          <slot name="icon" />
        </div>
      )}

      {badges.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 mb-2">
          {badges.map((badge) => (
            <span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold ${badge.color ?? 'bg-ink-100 text-ink-700'}`}>
              {badge.iconPath && (
                <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={badge.iconPath} />
                </svg>
              )}
              {badge.label}
            </span>
          ))}
        </div>
      )}

      {(preTitle || date) && (
        <div class="flex items-center gap-1.5 mb-2">
          {preTitle && <span class="text-xs font-semibold uppercase tracking-widest text-teal-700">{preTitle}</span>}
          {preTitle && date && <span class="text-ink-300" aria-hidden="true">·</span>}
          {date && <time class="text-xs text-ink-400">{date}</time>}
        </div>
      )}

      <h3 class="text-base font-bold text-ink-900 leading-snug group-hover:text-teal-700 transition-colors">{title}</h3>

      {description && (
        <p class="mt-2 text-sm text-ink-500 line-clamp-3">{description}</p>
      )}

      {ctaLabel && href && (
        <div class="mt-auto pt-4">
          <a href={href} class="btn-text text-sm">{ctaLabel}</a>
        </div>
      )}
    </div>
  </article>
)}
