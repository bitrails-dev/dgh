---
const { item, lang, categoryLabel, readLabel, basePath = "news" } = Astro.props;
const title = lang === "ar" ? item.data.titleAr : item.data.title;
const excerpt = lang === "ar"
  ? (item.data.excerptAr ?? item.data.summaryAr ?? "")
  : (item.data.excerpt   ?? item.data.summary   ?? "");
const href = `/${lang}/${basePath}/${item.id}`;
const hasThumbnail = item.data.thumbnail && !item.data.thumbnail.includes("picsum");
const categoryColors: Record<string, string> = {
  "hospital-news": "bg-secondary/10 text-secondary",
  "health-tips":   "bg-green-600/10 text-green-700",
  "research":      "bg-primary/10 text-primary",
  "events":        "bg-accent/15 text-accent",
};
const categoryClass = categoryColors[item.data.category] ?? "bg-muted/10 text-muted";
const dateStr = item.data.date
  ? new Date(item.data.date).toLocaleDateString(lang === "ar" ? "ar-EG" : "en-US", {
      year: "numeric", month: "short", day: "numeric",
    })
  : "";
---
<article class="group flex flex-col overflow-hidden rounded-2xl bg-surface shadow-soft transition-all duration-300 hover:-translate-y-1 hover:shadow-layered">
  <!-- Thumbnail or color placeholder -->
  {hasThumbnail ? (
    <img
      src={item.data.thumbnail}
      alt={title}
      width="400"
      height="176"
      class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  ) : (
    <div class="h-44 w-full bg-gradient-to-br from-primary/80 to-secondary/80 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
    </div>
  )}

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center justify-between gap-2">
      <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ${categoryClass}`}>{categoryLabel}</span>
      {dateStr && <time class="text-xs text-muted/70">{dateStr}</time>}
    </div>
    <h3 class="mt-3 text-base font-bold text-text leading-snug group-hover:text-primary transition-colors">{title}</h3>
    {excerpt && <p class="mt-2 text-sm text-muted line-clamp-2">{excerpt}</p>}
    <a href={href} class="mt-auto pt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-secondary hover:gap-3 transition-all">
      <span>{readLabel}</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  </div>
</article>
