---
interface Props {
  lang: string;
  strings: any;
  features?: string[];
}

import { localePath } from '../../i18n';

const { lang, strings, features } = Astro.props;

// A nav item is shown unless its capability is gated off for this tenant. `features === undefined`
// (single-tenant / unresolved) shows everything. Items with no capability (home/about/contact) always show.
const gated = (feature?: string) => !!features && !!feature && !features.includes(feature);

const currentUrl = Astro.url.pathname;

// lang switch: ar pages have no prefix (/about), en pages have /en prefix (/en/about)
const langSwitchUrl = lang === 'ar'
  ? (currentUrl === '/' ? '/en/' : `/en${currentUrl}`)
  : (currentUrl.replace(/^\/en/, '') || '/');

const currentPathClean = currentUrl.replace(/\/$/, '') || '/';

const navItems = [
  { id: 'home',         href: localePath('/', lang),             label: strings.nav?.home,         feature: undefined },
  { id: 'about',        href: localePath('/about', lang),        label: strings.nav?.about,        feature: undefined },
  { id: 'departments',  href: localePath('/departments', lang),  label: strings.nav?.departments,  feature: 'departments' },
  { id: 'team',         href: localePath('/team', lang),         label: strings.nav?.team,         feature: 'team' },
  { id: 'achievements', href: localePath('/achievements', lang), label: strings.nav?.achievements, feature: 'achievements' },
  { id: 'awards',       href: localePath('/awards', lang),       label: strings.nav?.awards,       feature: 'awards' },
  { id: 'articles',     href: localePath('/articles', lang),     label: strings.nav?.articles,     feature: 'articles' },
  { id: 'events',       href: localePath('/events', lang),       label: strings.nav?.events,       feature: 'events' },
  { id: 'contact',      href: localePath('/contact', lang),      label: strings.nav?.contact,      feature: undefined },
].filter((item) => !gated(item.feature));
---

<header data-topbar class="sticky top-0 z-50" style="background:rgba(251,248,242,0.85); backdrop-filter:saturate(1.4) blur(14px); -webkit-backdrop-filter:saturate(1.4) blur(14px); border-bottom:1px solid rgba(21,80,79,0.08);">
  <div class="mx-auto flex w-full max-w-[1440px] items-center justify-between gap-6 px-6 lg:px-8 py-4">
    <!-- Brand -->
    <a href={localePath('/', lang)} class="flex items-center gap-3 shrink-0">
      <img src="/logo/logo-hex.svg" class="h-9 w-9 flex-shrink-0" alt="" aria-hidden="true" />
      <div>
        <div class="font-display-ar font-semibold text-lg text-navy-900 leading-tight">{strings.site?.name}</div>
        <div class="mt-0.5 text-[10px] tracking-widest text-teal-700 uppercase font-medium leading-none">{strings.site?.established}</div>
      </div>
    </a>

    <!-- Nav links - desktop only -->
    <nav class="hidden xl:flex items-center gap-1">
      {navItems.map((item) => {
        const itemPathClean = item.href.replace(/\/$/, '') || '/';
        const homeHref = localePath('/', lang).replace(/\/$/, '') || '/';
        const isActive = currentPathClean === itemPathClean || (itemPathClean !== homeHref && currentPathClean.startsWith(itemPathClean));
        return (
          <a
            href={item.href}
            class:list={[
              'relative px-3 py-2 text-sm font-medium rounded-md transition-colors',
              isActive
                ? 'text-navy-900'
                : 'text-ink-700 hover:text-teal-800',
            ]}
          >
            {item.label}
            {isActive && (
              <span class="absolute bottom-0 inset-x-1.5 h-0.5 rounded-full bg-teal-600" />
            )}
          </a>
        );
      })}
    </nav>

    <!-- Utility (desktop: lang; mobile: hamburger only) -->
    <div class="flex items-center gap-2 shrink-0">
      <!-- Language toggle (desktop only) -->
      <a
        href={langSwitchUrl}
        class="hidden xl:inline-flex items-center gap-1.5 px-3 py-1.5 border border-ink-200 rounded-full text-sm font-medium text-ink-700 hover:border-teal-600 hover:text-teal-800 transition-colors"
      >
        {lang === 'ar' ? strings.nav?.toggleToEn : strings.nav?.toggleToAr}
      </a>

      <!-- Hamburger (mobile/tablet only) -->
      <button
        id="sidebar-hamburger"
        class="xl:hidden rounded-lg p-2 text-ink-700 hover:text-teal-800 transition-colors"
        aria-label={strings.sidebar?.expand ?? 'Open menu'}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  function onHamburgerClick() {
    window.dispatchEvent(new CustomEvent('toggle-sidebar'));
  }
  function bindHamburger() {
    const hamburger = document.getElementById('sidebar-hamburger');
    if (hamburger) {
      hamburger.removeEventListener('click', onHamburgerClick);
      hamburger.addEventListener('click', onHamburgerClick);
    }
  }
  document.addEventListener('astro:page-load', bindHamburger);
</script>
