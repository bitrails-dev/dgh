---
interface Props {
  lang: string;
  strings: any;
}

const { lang, strings } = Astro.props;

const otherLang = lang === 'ar' ? 'en' : 'ar';
const currentUrl = Astro.url.pathname;
const segments = currentUrl.split('/').filter(Boolean);
const langSwitchUrl = segments.length && (segments[0] === 'ar' || segments[0] === 'en')
  ? `/${[otherLang, ...segments.slice(1)].join('/')}`
  : `/${otherLang}${currentUrl}`;

const currentPathClean = currentUrl.replace(/\/$/, '') || '/';

const navItems = [
  { id: 'home',         href: `/${lang}/`,            label: strings.nav?.home },
  { id: 'about',        href: `/${lang}/about`,       label: strings.nav?.about },
  { id: 'departments',  href: `/${lang}/departments`, label: strings.nav?.departments },
  { id: 'team',         href: `/${lang}/team`,        label: strings.nav?.team },
  { id: 'achievements', href: `/${lang}/achievements`,label: strings.nav?.achievements },
  { id: 'awards',       href: `/${lang}/awards`,      label: strings.nav?.awards },
  { id: 'articles',     href: `/${lang}/articles`,    label: strings.nav?.articles },
  { id: 'events',       href: `/${lang}/events`,      label: strings.nav?.events },
  { id: 'contact',      href: `/${lang}/contact`,     label: strings.nav?.contact },
];
---

<header data-topbar class="sticky top-0 z-50" style="background:rgba(251,248,242,0.85); backdrop-filter:saturate(1.4) blur(14px); -webkit-backdrop-filter:saturate(1.4) blur(14px); border-bottom:1px solid rgba(21,80,79,0.08);">
  <div class="mx-auto flex w-full max-w-[1440px] items-center justify-between gap-6 px-6 lg:px-8 py-4">
    <!-- Brand -->
    <a href={`/${lang}/`} class="flex items-center gap-3 shrink-0">
      <svg class="h-9 w-9" viewBox="0 0 100 100" aria-hidden="true">
        <defs>
          <linearGradient id="topbar-hex" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#2a8f87" />
            <stop offset="1" stop-color="#112a4d" />
          </linearGradient>
        </defs>
        <path d="M50 4 L88 25 L88 75 L50 96 L12 75 L12 25 Z" fill="url(#topbar-hex)" />
        <path d="M50 4 L88 25 L88 75 L50 96 L12 75 L12 25 Z" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
        <path d="M54 22 L54 56 L34 56 Z" fill="#fff" />
        <path d="M56 30 L56 56 L68 56 Z" fill="#fff" opacity="0.55" />
        <path d="M14 66 L34 66 L38 58 L44 74 L50 62 L56 70 L62 66 L86 66" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div>
        <div class="font-display-ar font-semibold text-lg text-navy-900 leading-tight">{strings.site?.name}</div>
        <div class="mt-0.5 inline-block rounded-sm border border-teal-600/40 px-1.5 py-px text-[9px] tracking-widest text-teal-700 uppercase font-semibold leading-none">{strings.site?.established}</div>
      </div>
    </a>

    <!-- Nav links - desktop only -->
    <nav class="hidden xl:flex items-center gap-1">
      {navItems.map((item) => {
        const itemPathClean = item.href.replace(/\/$/, '') || '/';
        const isActive = currentPathClean === itemPathClean || (itemPathClean !== `/${lang}` && currentPathClean.startsWith(itemPathClean));
        return (
          <a
            href={item.href}
            class:list={[
              'relative px-3 py-2 text-sm font-medium rounded-md transition-colors',
              isActive
                ? 'text-navy-900'
                : 'text-ink-700 hover:text-teal-800',
            ]}
          >
            {item.label}
            {isActive && (
              <span class="absolute bottom-0 inset-x-1.5 h-0.5 rounded-full bg-teal-600" />
            )}
          </a>
        );
      })}
    </nav>

    <!-- Utility (desktop: lang; mobile: hamburger only) -->
    <div class="flex items-center gap-2 shrink-0">
      <!-- Language toggle (desktop only) -->
      <a
        href={langSwitchUrl}
        class="hidden xl:inline-flex items-center gap-1.5 px-3 py-1.5 border border-ink-200 rounded-full text-sm font-medium text-ink-700 hover:border-teal-600 hover:text-teal-800 transition-colors"
      >
        {lang === 'ar' ? strings.nav?.toggleToEn : strings.nav?.toggleToAr}
      </a>

      <!-- Hamburger (mobile/tablet only) -->
      <button
        id="sidebar-hamburger"
        class="xl:hidden rounded-lg p-2 text-ink-700 hover:text-teal-800 transition-colors"
        aria-label={strings.sidebar?.expand ?? 'Open menu'}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  function onHamburgerClick() {
    window.dispatchEvent(new CustomEvent('toggle-sidebar'));
  }
  function bindHamburger() {
    const hamburger = document.getElementById('sidebar-hamburger');
    if (hamburger) {
      hamburger.removeEventListener('click', onHamburgerClick);
      hamburger.addEventListener('click', onHamburgerClick);
    }
  }
  document.addEventListener('astro:page-load', bindHamburger);
</script>
