---
import SectionLabel from "../ui/SectionLabel.astro";

import { localePath } from '../../i18n';

const { lang, strings, features } = Astro.props as { lang: string; strings: any; features?: string[] };
const year = new Date().getFullYear();

// Gate quick-links by tenant capability. undefined features = single-tenant fallback (show all).
const gated = (feature?: string) => !!features && !!feature && !features.includes(feature);
const quickLinks = [
  { href: localePath('/about', lang),        label: strings.nav.about,        feature: undefined },
  { href: localePath('/departments', lang),  label: strings.nav.departments,  feature: 'departments' },
  { href: localePath('/achievements', lang), label: strings.nav.achievements, feature: 'achievements' },
  { href: localePath('/team', lang),         label: strings.nav.team,         feature: 'team' },
  { href: localePath('/events', lang),       label: strings.nav.events,       feature: 'events' },
  { href: localePath('/privacy', lang),      label: strings.footer.privacy,   feature: undefined },
  { href: localePath('/terms', lang),        label: strings.footer.terms,     feature: undefined },
].filter((l) => !gated(l.feature));

const emergency = strings.contact?.details?.emergencyNumber ?? '12345';
const social = Astro.locals.tenant?.contact?.social ?? {};
---
<footer class="bg-navy-900 text-navy-200">
  <div class="mx-auto w-full max-w-[1440px] px-6 py-16">
    <div class="grid gap-10 lg:grid-cols-4">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <img src="/logo/logo-hex.svg" class="h-10 w-10 flex-shrink-0" alt="" aria-hidden="true" />
          <p class="text-xl font-bold leading-tight text-white">{strings.site.name}</p>
        </div>
        <p class="mt-3 text-sm text-navy-200/60 leading-relaxed">{strings.site.tagline}</p>
      </div>

      <!-- Quick links -->
      <div>
        <SectionLabel text={strings.footer.quickLinks} class="text-white/70" />
        <ul class="mt-4 space-y-2 text-sm">
          {quickLinks.map((l) => (
            <li><a href={l.href} class="text-navy-200/70 transition-colors hover:text-teal-400">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Departments -->
      <div>
        <SectionLabel text={strings.footer.departments} class="text-white/70" />
        <ul class="mt-4 space-y-2 text-sm text-navy-200/60">
          {strings.footer.departmentList.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <SectionLabel text={strings.footer.contact} class="text-white/70" />
        <ul class="mt-4 space-y-2 text-sm text-navy-200/60">
          {strings.footer.contactLines.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <!-- Emergency badge -->
        <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-coral/15 px-3 py-1.5 text-xs font-semibold text-coral">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-coral opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-coral"></span>
          </span>
          {lang === "ar" ? `طوارئ: ${emergency}` : `Emergency: ${emergency}`}
        </div>
      </div>

    </div>

    <!-- Social + bottom bar -->
    <div class="mt-10 flex flex-wrap items-center justify-between gap-6 border-t border-white/8 pt-8">
      <!-- Social icons -->
      <div class="flex items-center gap-4 text-navy-200/60">
        <a
          href={social.facebookUrl || "#"}
          aria-label={strings.footer.social.facebook}
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 transition-colors hover:border-teal-400 hover:text-teal-400"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M13 9h3V6h-3c-2.2 0-4 1.8-4 4v2H7v3h2v6h3v-6h3l1-3h-4v-2c0-.6.4-1 1-1z"/>
          </svg>
        </a>
        <a
          href={social.xUrl || "#"}
          aria-label={strings.footer.social.x}
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 transition-colors hover:border-teal-400 hover:text-teal-400"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M4 4l7.5 8.5L4.5 20H8l5.5-6.3L19 20h3L14 11.4 21.1 4h-3.5l-4.9 5.7L8.1 4H4z"/>
          </svg>
        </a>
        <a
          href={social.youtubeUrl || "#"}
          aria-label={strings.footer.social.youtube}
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 transition-colors hover:border-teal-400 hover:text-teal-400"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M22.5 7.2a2.8 2.8 0 00-2-2C18.6 4.7 12 4.7 12 4.7s-6.6 0-8.5.5a2.8 2.8 0 00-2 2A29 29 0 001 12a29 29 0 00.5 4.8 2.8 2.8 0 002 2c1.9.5 8.5.5 8.5.5s6.6 0 8.5-.5a2.8 2.8 0 002-2A29 29 0 0023 12a29 29 0 00-.5-4.8zM10 15.5V8.5l6 3.5-6 3.5z"/>
          </svg>
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-xs text-white/50">{year} &copy; {strings.site.name}. {strings.footer.rights}.</p>
    </div>
  </div>
</footer>
