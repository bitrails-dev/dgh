---
import SectionLabel from "../ui/SectionLabel.astro";

const { lang, strings } = Astro.props;
const year = new Date().getFullYear();
const basePath = `/${lang}`;
---
<footer class="bg-primary text-white">
  <div class="container mx-auto py-16">
    <div class="grid gap-10 lg:grid-cols-4">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <!-- Hospital cross icon -->
          <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-accent/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <rect x="10" y="3" width="4" height="18" rx="1.5"/>
              <rect x="3" y="10" width="18" height="4" rx="1.5"/>
            </svg>
          </div>
          <p class="text-xl font-bold leading-tight">{strings.site.name}</p>
        </div>
        <p class="mt-3 text-sm text-white/60 leading-relaxed">{strings.site.tagline}</p>
      </div>

      <!-- Quick links -->
      <div>
        <SectionLabel text={strings.footer.quickLinks} class="text-white/70" />
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={`${basePath}/#about`} class="text-white/70 transition-colors hover:text-accent">{strings.nav.about}</a></li>
          <li><a href={`${basePath}/#departments`} class="text-white/70 transition-colors hover:text-accent">{strings.nav.departments}</a></li>
          <li><a href={`${basePath}/#achievements`} class="text-white/70 transition-colors hover:text-accent">{strings.nav.achievements}</a></li>
          <li><a href={`${basePath}/#team`} class="text-white/70 transition-colors hover:text-accent">{strings.nav.team}</a></li>
          <li><a href={`${basePath}/#news`} class="text-white/70 transition-colors hover:text-accent">{strings.nav.news}</a></li>
          <li><a href={`${basePath}/privacy`} class="text-white/70 transition-colors hover:text-accent">{strings.footer.privacy}</a></li>
          <li><a href={`${basePath}/terms`} class="text-white/70 transition-colors hover:text-accent">{strings.footer.terms}</a></li>
        </ul>
      </div>

      <!-- Departments -->
      <div>
        <SectionLabel text={strings.footer.departments} class="text-white/70" />
        <ul class="mt-4 space-y-2 text-sm text-white/60">
          {strings.footer.departmentList.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <SectionLabel text={strings.footer.contact} class="text-white/70" />
        <ul class="mt-4 space-y-2 text-sm text-white/60">
          {strings.footer.contactLines.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <!-- Emergency badge -->
        <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-red-600/15 px-3 py-1.5 text-xs font-semibold text-red-400">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-red-500"></span>
          </span>
          {lang === "ar" ? "طوارئ: 12345" : "Emergency: 12345"}
        </div>
      </div>

    </div>

    <!-- Social + bottom bar -->
    <div class="mt-10 flex flex-wrap items-center justify-between gap-6 border-t border-white/10 pt-8">
      <!-- Social icons -->
      <div class="flex items-center gap-4 text-white/60">
        <a
          href="#"
          aria-label={strings.footer.social.facebook}
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 transition-colors hover:border-accent hover:text-accent"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M13 9h3V6h-3c-2.2 0-4 1.8-4 4v2H7v3h2v6h3v-6h3l1-3h-4v-2c0-.6.4-1 1-1z"/>
          </svg>
        </a>
        <a
          href="#"
          aria-label={strings.footer.social.x}
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 transition-colors hover:border-accent hover:text-accent"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M4 4l7.5 8.5L4.5 20H8l5.5-6.3L19 20h3L14 11.4 21.1 4h-3.5l-4.9 5.7L8.1 4H4z"/>
          </svg>
        </a>
        <a
          href="#"
          aria-label={strings.footer.social.youtube}
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 transition-colors hover:border-accent hover:text-accent"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M22.5 7.2a2.8 2.8 0 00-2-2C18.6 4.7 12 4.7 12 4.7s-6.6 0-8.5.5a2.8 2.8 0 00-2 2A29 29 0 001 12a29 29 0 00.5 4.8 2.8 2.8 0 002 2c1.9.5 8.5.5 8.5.5s6.6 0 8.5-.5a2.8 2.8 0 002-2A29 29 0 0023 12a29 29 0 00-.5-4.8zM10 15.5V8.5l6 3.5-6 3.5z"/>
          </svg>
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-xs text-white/50">{year} &copy; {strings.site.name}. {strings.footer.rights}.</p>
    </div>
  </div>
</footer>
