---
import { getCollection } from "../../lib/cms";
import { localePath } from "../../i18n";
import CardBase from "../ui/CardBase.astro";
import CardGrid from "../ui/CardGrid.astro";

const { lang, strings } = Astro.props;
const isAr = lang === "ar";
const doctors = await getCollection("doctors", Astro.locals.tenant?.id);
const sortByOrder = (a: any, b: any) => (a.data.order ?? 999) - (b.data.order ?? 999);
const featured = doctors.filter((doc) => doc.data.featured).sort(sortByOrder);
const others = doctors.filter((doc) => !doc.data.featured).sort(sortByOrder);
const displayDoctors = featured.length > 0 ? featured.slice(0, 3) : others.slice(0, 3);
---

<section id="team" class="bg-ivory-50" style="padding: 96px 0;">
	<div class="container mx-auto">
		<!-- Section header: split grid -->
		<div class="section-header grid gap-8 mb-14" style="grid-template-columns: 1fr 1.6fr;">
			<div>
				<div class="inline-flex items-center gap-2.5 mb-4">
					<div class="w-8 h-px bg-teal-600"></div>
					<p class="h-eyebrow">{isAr ? 'فريقنا الطبي' : 'Our Medical Team'}</p>
				</div>
				<h2 class="font-display-ar font-medium text-navy-900 leading-none tracking-tight" style="font-size: clamp(36px, 4vw, 56px); line-height: 1.1;">
					{strings.team.title}
				</h2>
			</div>
			<div class="flex items-end">
				<p class="text-body-lg text-ink-500 leading-relaxed">{strings.team.subtitle}</p>
			</div>
		</div>

		<CardGrid cols={3} gap="md">
			{displayDoctors.map((doctor) => {
				const name = isAr ? doctor.data.nameAr : doctor.data.name;
				const specialty = isAr ? doctor.data.specialtyAr : doctor.data.specialty;
				const bio = isAr ? doctor.data.bioAr : doctor.data.bio;
				const href = localePath(`/doctors/${doctor.id}`, lang);
				const imageBadge = doctor.data.certified
					? { label: strings.team.certified, iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' }
					: undefined;
				return (
					<CardBase
						href={href}
						image={doctor.data.photo}
						imageAlt={name}
						title={name}
						preTitle={specialty}
						description={bio}
						ctaLabel={`${strings.team.profileLabel} →`}
						imageBadge={imageBadge}
						imageHeight="h-96"
					/>
				);
			})}
		</CardGrid>
	</div>
</section>

<style>
	@media (max-width: 900px) {
		.section-header { grid-template-columns: 1fr !important; gap: 16px !important; }
	}
</style>
