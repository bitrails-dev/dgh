---
import { getCollection } from "astro:content";
import GoldHeading from "../ui/GoldHeading.astro";
import CardDoctor from "../ui/CardDoctor.astro";

const { lang, strings } = Astro.props;
const doctors = await getCollection("doctors");
const featured = doctors.filter((doc) => doc.data.featured);
const others   = doctors.filter((doc) => !doc.data.featured);
---
<section id="team" class="bg-background py-20">
  <div class="container mx-auto">

    <div data-animate="fade">
      <GoldHeading text={strings.team.title} />
      <p class="mt-4 max-w-2xl text-sm text-muted">{strings.team.subtitle}</p>
    </div>

    <!-- Featured / leadership -->
    {featured.length > 0 && (
      <div class="mt-12" data-animate="fade">
        <h3 class="mb-6 text-lg font-bold text-text">{strings.team.featuredTitle}</h3>
        <div class="grid gap-6 lg:grid-cols-3">
          {featured.map((doctor) => {
            const name      = lang === "ar" ? doctor.data.nameAr    : doctor.data.name;
            const specialty = lang === "ar" ? doctor.data.specialtyAr : doctor.data.specialty;
            const bio       = lang === "ar" ? doctor.data.bioAr     : doctor.data.bio;
            const href      = `/${lang}/doctors/${doctor.slug}`;
            return (
              <article class="group overflow-hidden rounded-2xl bg-surface shadow-layered transition-all duration-300 hover:-translate-y-1 hover:shadow-deep">
                <div class="relative overflow-hidden">
                  <img
                    src={doctor.data.photo}
                    alt={name}
                    width="400"
                    height="240"
                    class="h-60 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                  {doctor.data.certified && (
                    <span class="absolute top-3 end-3 inline-flex items-center gap-1 rounded-full bg-accent/90 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                      <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-white" aria-hidden="true">
                        <path d="M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z"/>
                      </svg>
                      {strings.team.certified}
                    </span>
                  )}
                </div>
                <div class="p-6">
                  <h4 class="text-xl font-bold text-text">{name}</h4>
                  <p class="mt-1 text-sm font-medium text-secondary">{specialty}</p>
                  <p class="mt-3 text-sm text-muted line-clamp-3">{bio}</p>
                  <a
                    href={href}
                    class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:gap-3 transition-all"
                  >
                    {strings.team.profileLabel}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    )}

    <!-- All other doctors -->
    {others.length > 0 && (
      <div class="mt-14" data-animate="fade">
        <h3 class="mb-6 text-lg font-bold text-text">{strings.team.doctorsTitle}</h3>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {others.map((doctor) => (
            <CardDoctor
              doctor={doctor}
              lang={lang}
              certifiedLabel={strings.team.certified}
              profileLabel={strings.team.profileLabel}
              imageAlt={lang === "ar" ? doctor.data.nameAr : doctor.data.name}
            />
          ))}
        </div>
      </div>
    )}

  </div>
</section>
