---
import { getCollection } from "astro:content";
import GoldHeading from "../ui/GoldHeading.astro";
import CardNews from "../ui/CardNews.astro";

const { lang, strings } = Astro.props;

// Show all news sorted by date (bilingual fields in each file)
const newsItems = (await getCollection("news"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<section id="news" class="bg-background py-20">
  <div class="container mx-auto">
    <div data-animate="fade">
      <GoldHeading text={strings.news.title} />
      <p class="mt-4 max-w-2xl text-sm text-muted">{strings.news.subtitle}</p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-animate="fade">
      {newsItems.length > 0 ? (
        newsItems.map((item) => (
          <CardNews
            item={item}
            lang={lang}
            categoryLabel={strings.news.category[item.data.category] ?? item.data.category}
            readLabel={strings.links.readMore}
          />
        ))
      ) : (
        <p class="col-span-3 text-center text-sm text-muted py-12">
          {lang === "ar" ? "لا توجد أخبار حالياً." : "No news available yet."}
        </p>
      )}
    </div>

    <div class="mt-10 text-center" data-animate="fade">
      <a
        href={`/${lang}/news`}
        class="inline-flex items-center gap-2 rounded-xl border-2 border-primary px-7 py-3 text-sm font-bold text-primary transition-all hover:bg-primary hover:text-white"
      >
        {strings.news.cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </div>
</section>
