---
import { getCollection } from "astro:content";
import CardBase from "../ui/CardBase.astro";
import CardGrid from "../ui/CardGrid.astro";

const { lang, strings } = Astro.props;
const isAr = lang === "ar";
const departments = await getCollection("departments");

const iconPaths: Record<string, string> = {
  "heart-pulse": "M12 21s-6.5-4.4-9-8.3C1.2 10.6 1 8 2.5 6.2 4 4.4 6.8 4.1 8.7 5.5L12 8l3.3-2.5c2-1.4 4.7-1.1 6.2.7 1.5 1.8 1.3 4.4-.5 6.5-2.5 3-9 8.3-9 8.3z",
  stethoscope: "M6 2v5a4 4 0 008 0V2M12 12v2a4 4 0 008 0v-1M20 13a3 3 0 11-6 0 3 3 0 016 0z",
  radiation: "M12 12a2 2 0 100-4 2 2 0 000 4zm0 2a3.5 3.5 0 01-3.3-2.3l-3.1.8a6.5 6.5 0 005.9 4.5l.5-3zm3.3-4.3a3.5 3.5 0 01-3.3 2.3l.5 3a6.5 6.5 0 005.9-4.5l-3.1-.8zM11 4.1l1 2.8a6.5 6.5 0 00-2.6.7L7.7 4.9a9.5 9.5 0 013.3-.8z",
  baby: "M12 5a4 4 0 100 8 4 4 0 000-8zm-5.5 9.5a7.5 7.5 0 0111 0M9 8h.01M15 8h.01",
  scan: "M4 7V4h3M20 7V4h-3M4 17v3h3M20 17v3h-3M8 12h8",
  flower: "M12 12a3 3 0 100-6 3 3 0 000 6zm0 0a3 3 0 100 6 3 3 0 000-6zm0 0a3 3 0 10-6 0 3 3 0 006 0zm0 0a3 3 0 106 0 3 3 0 00-6 0z",
};
const defaultIcon = "M12 2l8 4v6c0 5-3.5 9.7-8 12-4.5-2.3-8-7-8-12V6l8-4z";
---

<section id="departments" class="bg-ivory-50" style="padding: 96px 0;">
	<div class="container mx-auto">
		<!-- Section header: split grid -->
		<div class="section-header grid gap-8 mb-14" style="grid-template-columns: 1fr 1.6fr;">
			<div>
				<div class="inline-flex items-center gap-2.5 mb-4">
					<div class="w-8 h-px bg-teal-600"></div>
					<p class="h-eyebrow">{isAr ? 'تخصصاتنا' : 'Our Specialties'}</p>
				</div>
				<h2 class="font-display-ar font-medium text-navy-900 leading-none tracking-tight" style="font-size: clamp(36px, 4vw, 56px); line-height: 1.1;">
					{strings.departments.title}
				</h2>
			</div>
			<div class="flex items-end">
				<p class="text-body-lg text-ink-500 leading-relaxed">{strings.departments.subtitle}</p>
			</div>
		</div>

		<CardGrid cols={3} gap="none">
			{departments.map((dept) => {
				const name = isAr ? dept.data.nameAr : dept.data.name;
				const description = isAr ? dept.data.descriptionAr : dept.data.description;
				const href = `/${lang}/departments/${dept.id}`;
				const iconPath = iconPaths[dept.data.icon as string] ?? defaultIcon;
				const imageBadge = dept.data.centerOfExcellence
					? { label: strings.departments.centerOfExcellence, iconPath: 'M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z', color: 'bg-gold/15 text-gold' }
					: undefined;
				return (
					<CardBase
						href={href}
						iconPath={iconPath}
						title={name}
						description={description}
						ctaLabel={`${strings.links.viewDepartment} →`}
						imageBadge={imageBadge}
					/>
				);
			})}
		</CardGrid>
	</div>
</section>

<style>
	@media (max-width: 900px) {
		.section-header { grid-template-columns: 1fr !important; gap: 16px !important; }
	}
</style>
