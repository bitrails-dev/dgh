---
import { getCollection } from 'astro:content';
import { localePath } from '../../i18n';
import CardBase from '../ui/CardBase.astro';
import CardGrid from '../ui/CardGrid.astro';

const { lang, strings } = Astro.props;
const isAr = lang === 'ar';
const departments = await getCollection('departments');

const iconPaths: Record<string, string> = {
	'heart-pulse':
		'<path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1A5.5 5.5 0 1 0 3.2 12.4l8.8 8.8 8.8-8.8a5.5 5.5 0 0 0 0-7.8Z"/>',
	stethoscope:
		'<path d="M4.8 2.5v5a4.5 4.5 0 0 0 9 0v-5"/><path d="M4.8 2.5h2M11.8 2.5h2"/><path d="M9.3 12v4.5a4.5 4.5 0 0 0 9 0v-1"/><circle cx="18.3" cy="11" r="2"/>',
	brain:
		'<path d="M12 4a3 3 0 0 0-3 3v1a3 3 0 0 0-2 2.8v.4a3 3 0 0 0 2 2.8v.2A3 3 0 0 0 12 17a3 3 0 0 0 3-2.8V14a3 3 0 0 0 2-2.8v-.4a3 3 0 0 0-2-2.8V7a3 3 0 0 0-3-3Z"/><path d="M12 4v13M9 7.5c0 1 1 1.5 1.5 1.5M15 7.5c0 1-1 1.5-1.5 1.5"/>',
	baby: '<circle cx="12" cy="7" r="3"/><path d="M7 21c0-3 2-5 5-5s5 2 5 5"/><path d="M10 7h.01M14 7h.01"/>',
	bone: '<path d="M17 3a2.5 2.5 0 0 1 1.8 4.3A2.5 2.5 0 0 1 21 12a2.5 2.5 0 0 1-2.2 4.7A2.5 2.5 0 0 1 17 21a2.5 2.5 0 0 1-4.7-2.2A2.5 2.5 0 0 1 8 21a2.5 2.5 0 0 1-1.8-4.3A2.5 2.5 0 0 1 3 12a2.5 2.5 0 0 1 2.2-4.7A2.5 2.5 0 0 1 7 3a2.5 2.5 0 0 1 4.7 2.2A2.5 2.5 0 0 1 17 3Z"/>',
	eye: '<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/>',
	cross:
		'<path d="M17 3a2.5 2.5 0 0 1 1.8 4.3A2.5 2.5 0 0 1 21 12a2.5 2.5 0 0 1-2.2 4.7A2.5 2.5 0 0 1 17 21a2.5 2.5 0 0 1-4.7-2.2A2.5 2.5 0 0 1 8 21a2.5 2.5 0 0 1-1.8-4.3A2.5 2.5 0 0 1 3 12a2.5 2.5 0 0 1 2.2-4.7A2.5 2.5 0 0 1 7 3a2.5 2.5 0 0 1 4.7 2.2A2.5 2.5 0 0 1 17 3Z"></path>',
	pill: '<rect x="3" y="8" width="18" height="8" rx="4"/><path d="M12 8v8"/>',
	microscope: '<path d="M6 18h12M8 21h8M10 18v-3l-3-6 3-6h1l3 3-3 3 3 6"/>',
	syringe:
		'<path d="M18 2l-4 4M17 3l4 4M7.5 12.5L18 2M3 22l3-3M6 19l-3 3M9 13l-2.5 2.5"/>',
	scapel:
		'<path d="M17 3a2.5 2.5 0 0 1 1.8 4.3A2.5 2.5 0 0 1 21 12a2.5 2.5 0 0 1-2.2 4.7A2.5 2.5 0 0 1 17 21a2.5 2.5 0 0 1-4.7-2.2A2.5 2.5 0 0 1 8 21a2.5 2.5 0 0 1-1.8-4.3A2.5 2.5 0 0 1 3 12a2.5 2.5 0 0 1 2.2-4.7A2.5 2.5 0 0 1 7 3a2.5 2.5 0 0 1 4.7 2.2A2.5 2.5 0 0 1 17 3Z"></path>',
	activity:
		'<path d="M4.8 2.5v5a4.5 4.5 0 0 0 9 0v-5"/><path d="M4.8 2.5h2M11.8 2.5h2"/><path d="M9.3 12v4.5a4.5 4.5 0 0 0 9 0v-1"/><circle cx="18.3" cy="11" r="2"/>',
};
const defaultIcon =
	'<path d="M12 2l8 4v6c0 5-3.5 9.7-8 12-4.5-2.3-8-7-8-12V6l8-4z"/>';
---

<section id='departments' class='bg-ivory-50' style='padding: 96px 0;'>
	<div class='container mx-auto'>
		<!-- Section header: split grid -->
		<div
			class='section-header grid gap-8 mb-14'
			style='grid-template-columns: 1fr 1.6fr;'
		>
			<div>
				<div class='inline-flex items-center gap-2.5 mb-4'>
					<div class='w-8 h-px bg-teal-600'></div>
					<p class='h-eyebrow'>{isAr ? 'تخصصاتنا' : 'Our Specialties'}</p>
				</div>
				<h2
					class='font-display-ar font-medium text-navy-900 leading-none tracking-tight'
					style='font-size: clamp(36px, 4vw, 56px); line-height: 1.1;'
				>
					{strings.departments.title}
				</h2>
			</div>
			<div class='flex items-end'>
				<p class='text-body-lg text-ink-500 leading-relaxed'>
					{strings.departments.subtitle}
				</p>
			</div>
		</div>

		<CardGrid cols={3} gap='none'>
			{
				departments.map(dept => {
					const name = isAr ? dept.data.nameAr : dept.data.name;
					const description = isAr
						? dept.data.descriptionAr
						: dept.data.description;
					const href = localePath(`/departments/${dept.id}`, lang);
					const iconPath = iconPaths[dept.data.icon as string] ?? defaultIcon;
					const imageBadge = dept.data.centerOfExcellence
						? {
								label: strings.departments.centerOfExcellence,
								iconPath:
									'M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z',
								color: 'bg-gold/15 text-gold',
							}
						: undefined;
					return (
						<CardBase
							href={href}
							iconPath={iconPath}
							title={name}
							description={description}
							ctaLabel={strings.links.viewDepartment}
							imageBadge={imageBadge}
						/>
					);
				})
			}
		</CardGrid>
	</div>
</section>

<style>
	@media (max-width: 900px) {
		.section-header {
			grid-template-columns: 1fr !important;
			gap: 16px !important;
		}
	}
</style>
