---
import SectionLabel from "../ui/SectionLabel.astro";

const { strings } = Astro.props;
const items = [
  { title: strings.mission.missionTitle, body: strings.mission.missionBody, icon: "M12 2l8 4v6c0 5-3.5 9.7-8 12-4.5-2.3-8-7-8-12V6l8-4z" },
  { title: strings.mission.visionTitle, body: strings.mission.visionBody, icon: "M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z M12 9a3 3 0 100 6 3 3 0 000-6z" },
  { title: strings.mission.valuesTitle, body: strings.mission.valuesBody, icon: "M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z" },
];
---
<section class="bg-background py-16">
  <div class="container mx-auto" data-animate="fade" transition:animate="fade">
    <div class="grid gap-8 lg:grid-cols-3">
      {items.map((item, index) => (
        <div class="relative rounded-2xl bg-surface p-6 shadow-soft">
          <svg viewBox="0 0 24 24" class="h-8 w-8 text-accent" aria-hidden="true">
            <path d={item.icon} fill="currentColor" />
          </svg>
          <SectionLabel text={item.title} />
          <p class="mt-3 text-sm text-muted">{item.body}</p>
          {index < 2 && <div class="absolute top-6 right-0 rtl:left-0 rtl:right-auto h-12 w-px bg-accent/40"></div>}
        </div>
      ))}
    </div>
  </div>
</section>
