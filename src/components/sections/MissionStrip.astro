---
import SectionLabel from "../ui/SectionLabel.astro";

const { strings } = Astro.props;
const items = [
  {
    title: strings.mission.missionTitle,
    body:  strings.mission.missionBody,
    // Shield icon
    icon: "M12 2l8 4v6c0 5-3.5 9.7-8 12-4.5-2.3-8-7-8-12V6l8-4z",
  },
  {
    title: strings.mission.visionTitle,
    body:  strings.mission.visionBody,
    // Eye icon
    icon: "M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z M12 9a3 3 0 100 6 3 3 0 000-6z",
  },
  {
    title: strings.mission.valuesTitle,
    body:  strings.mission.valuesBody,
    // Star icon
    icon: "M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z",
  },
];
---
<section class="bg-background py-16">
  <div class="container mx-auto">
    <div class="grid gap-6 lg:grid-cols-3" data-animate="fade">
      {items.map((item, index) => (
        <div class="relative rounded-2xl bg-surface p-7 shadow-soft hover:shadow-layered transition-shadow duration-300">
          <!-- Icon circle -->
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-primary" aria-hidden="true">
              <path d={item.icon} fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <SectionLabel text={item.title} />
          <p class="mt-3 text-sm leading-relaxed text-muted">{item.body}</p>
          <!-- Vertical divider (between cards on desktop) -->
          {index < 2 && (
            <div class="absolute top-7 end-0 hidden h-16 w-px bg-gradient-to-b from-transparent via-accent/30 to-transparent lg:block"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
