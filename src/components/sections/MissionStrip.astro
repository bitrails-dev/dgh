---
const { lang, strings } = Astro.props;
const isAr = lang === 'ar';
---

<!-- About Spread section (replaces old MissionStrip) -->
<section id="about" class="bg-white border-y border-ink-100" style="padding: 96px 0;">
	<div class="container mx-auto">
		<div class="about-grid" style="display:grid; grid-template-columns: 1fr 1.2fr; gap:64px; align-items:center;">
			<!-- Photo placeholder -->
			<div class="relative aspect-[4/5] rounded-none overflow-hidden">
				<div class="absolute inset-0 bg-gradient-to-br from-teal-900 via-teal-700 to-teal-600 flex items-end p-7">
					<!-- Stripes overlay -->
					<div class="absolute inset-0" style="background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.04) 0, rgba(255,255,255,0.04) 2px, transparent 2px, transparent 14px)"></div>
					<!-- Label -->
					<div class="font-mono text-white/55 text-xs tracking-wide relative z-10">[ ABOUT_IMAGE &middot; hospital-interior.jpg &middot; 4:5 ]</div>
				</div>
			</div>

			<!-- Text side -->
			<div>
				<!-- Eyebrow -->
				<div class="inline-flex items-center gap-2.5 mb-4">
					<div class="w-8 h-px bg-teal-600"></div>
					<p class="h-eyebrow">{isAr ? 'عن المستشفى' : 'About Us'}</p>
				</div>

				<h2 class="font-display-ar font-medium text-navy-900 leading-none tracking-tight mb-8" style="font-size: clamp(36px, 4vw, 56px); line-height: 1.1;">
					{strings.mission.missionTitle}
				</h2>

				<p class="text-body-lg text-ink-700 leading-relaxed mb-6">{strings.mission.missionBody}</p>

				<p class="text-body text-ink-500 leading-relaxed mb-10">{strings.mission.valuesBody}</p>

				<!-- Vision card -->
				<div class="bg-white border border-ink-100 rounded-none p-8" style="box-shadow: 0 1px 2px rgba(15,59,61,0.04), 0 1px 3px rgba(15,59,61,0.06);">
					<div class="flex items-center gap-3 mb-4">
						<div class="w-10 h-10 rounded-full bg-teal-700/10 flex items-center justify-center">
							<svg viewBox="0 0 24 24" class="h-5 w-5 text-teal-700" aria-hidden="true">
								<path d="M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z M12 9a3 3 0 100 6 3 3 0 000-6z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</div>
						<h3 class="font-display-ar text-lg font-medium text-navy-900">{strings.mission.visionTitle}</h3>
					</div>
					<p class="text-ink-500 leading-relaxed">{strings.mission.visionBody}</p>
				</div>
			</div>
		</div>

		<!-- Ornamental divider -->
		<div class="flex items-center justify-center mt-20 gap-4">
			<div class="h-px flex-1 bg-ink-200"></div>
			<svg viewBox="0 0 24 24" class="h-5 w-5 text-teal-700/40" aria-hidden="true">
				<path d="M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z" fill="none" stroke="currentColor" stroke-width="1.5" />
			</svg>
			<div class="h-px flex-1 bg-ink-200"></div>
		</div>
	</div>
</section>

<style>
	@media (max-width: 900px) {
		.about-grid {
			grid-template-columns: 1fr !important;
			gap: 40px !important;
		}
		.about-grid > div:first-child {
			max-height: 360px;
			max-width: 320px;
			margin-inline: auto;
			width: 100%;
		}
	}
</style>
