---
const { lang, strings } = Astro.props;
const isAr = lang === "ar";

// Static article data using the events section strings + sample data
const articles = [
	{
		category: isAr ? 'تقارير' : 'Reports',
		date: '2025-03-15',
		title: isAr ? 'تطوير منظومة العناية المركزة' : 'ICU Modernization Initiative',
		excerpt: isAr ? 'مشروع شامل لتجديد وتطوير أقسام العناية المركزة بأحدث الأجهزة والتقنيات الطبية.' : 'A comprehensive project to renovate ICU departments with state-of-the-art medical equipment and technology.',
	},
	{
		category: isAr ? 'أبحاث' : 'Research',
		date: '2025-02-20',
		title: isAr ? 'إنجاز جراحي فريد في قسم القلب' : 'Landmark Cardiac Surgery Achievement',
		excerpt: isAr ? 'فريق جراحة القلب يحقق نجاحًا في عملية جراحية معقدة لأول مرة في المنطقة.' : 'The cardiac surgery team succeeds in a complex surgical procedure, a first in the region.',
	},
	{
		category: isAr ? 'أخبار' : 'News',
		date: '2025-01-10',
		title: isAr ? 'المستشفى تحصل على اعتماد جديد' : 'Hospital Receives New Accreditation',
		excerpt: isAr ? 'حصول المستشفى على اعتماد إقليمي جديد يعكس التزامها بمعايير الجودة العالمية.' : 'The hospital earns a new regional accreditation reflecting its commitment to global quality standards.',
	},
];
---

<!-- Articles section -->
<section class="bg-ivory-50" style="padding: 96px 0;">
	<div class="container mx-auto">
		<!-- Section header: split grid -->
		<div class="grid gap-8 mb-14" style="grid-template-columns: 1fr 1.6fr;">
			<div>
				<div class="inline-flex items-center gap-2.5 mb-4">
					<div class="w-8 h-px bg-teal-600"></div>
					<p class="h-eyebrow">{isAr ? 'آخر الأخبار' : 'Latest News'}</p>
				</div>
				<h2 class="font-display-ar font-medium text-navy-900 leading-none tracking-tight" style="font-size: clamp(36px, 4vw, 56px); line-height: 1.1;">
					{isAr ? 'مقالات وأخبار' : 'Articles & News'}
				</h2>
			</div>
			<div class="flex items-end">
				<p class="text-body-lg text-ink-500 leading-relaxed">{strings.events.subtitle}</p>
			</div>
		</div>

		<!-- 3-col articles grid -->
		<div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;">
			{articles.map((article) => (
				<article class="bg-ivory-50 overflow-hidden border border-ink-100 group transition-colors duration-200 hover:bg-white">
					<!-- Cover with teal gradient -->
					<div class="relative h-48 overflow-hidden">
						<div class="absolute inset-0 bg-gradient-to-br from-teal-900 via-teal-700 to-teal-600">
							<div class="absolute inset-0" style="background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.04) 0, rgba(255,255,255,0.04) 2px, transparent 2px, transparent 14px)"></div>
						</div>
						<!-- Category chip -->
						<div class="absolute top-4 start-4 bg-white px-3 py-1 rounded-full text-xs font-semibold text-navy-900">
							{article.category}
						</div>
					</div>
					<!-- Content -->
					<div class="p-6">
						<div class="font-mono text-xs text-ink-400 mb-3">{article.date}</div>
						<h3 class="font-display-ar text-lg font-medium text-navy-900 mb-3 leading-snug">{article.title}</h3>
						<p class="text-sm text-ink-500 leading-relaxed mb-4 line-clamp-2">{article.excerpt}</p>
						<div class="mb-2">
						<a href="#" class="btn-text text-sm">
							{strings.links.readMore} &rarr;
						</a>
					</div>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	@media (max-width: 900px) {
		div[style*="grid-template-columns: repeat(3"] {
			grid-template-columns: repeat(2, 1fr) !important;
		}
	}
	@media (max-width: 600px) {
		div[style*="grid-template-columns: repeat(3"] {
			grid-template-columns: 1fr !important;
		}
	}
</style>
