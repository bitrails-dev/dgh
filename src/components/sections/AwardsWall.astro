---
import { getCollection } from "astro:content";
import GoldHeading from "../ui/GoldHeading.astro";

const { lang, strings } = Astro.props;
const awards = await getCollection("awards");
---
<section class="bg-primary text-white section-stripes py-16">
  <div class="container mx-auto" data-animate="fade">
    <GoldHeading text={strings.achievements.awardsTitle} class="text-white border-accent" />
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {awards.map((award) => (
        <div class="group relative overflow-hidden rounded-2xl p-6 frosted-card transition-all duration-300 hover:border-accent/80 hover:-translate-y-1">
          <!-- Shimmer on hover -->
          <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(110deg,transparent_30%,rgba(255,255,255,0.15)_50%,transparent_70%)] opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

          <!-- Badge placeholder if no image -->
          {award.data.badgeImage ? (
            <img
              src={award.data.badgeImage}
              alt={strings.achievements.badgeAlt}
              width="64"
              height="64"
              class="h-16 w-16 rounded-lg object-contain"
              loading="lazy"
            />
          ) : (
            <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-accent/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="8" r="6"/>
                <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
              </svg>
            </div>
          )}

          <h3 class="mt-4 text-lg font-semibold">
            {lang === "ar" ? award.data.nameAr : award.data.name}
          </h3>
          <p class="mt-2 text-sm text-white/70">{award.data.body}</p>
          <p class="mt-3 inline-flex items-center rounded-full bg-accent/15 px-3 py-0.5 text-xs font-semibold text-accent">
            {award.data.year}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
