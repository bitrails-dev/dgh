---
const { lang, strings } = Astro.props;
const isAr = lang === 'ar';
const stats = [
	{ label: strings.hero.stats.years, value: isAr ? '٦٧' : '67', unit: '+' },
	{
		label: strings.hero.stats.departments,
		value: isAr ? '٢٨' : '28',
		unit: '',
	},
	{
		label: strings.hero.stats.patients,
		value: isAr ? '١٫٢' : '1.2',
		unit: isAr ? 'م+' : 'M+',
	},
	{
		label: strings.hero.stats.staff,
		value: isAr ? '٢٤٠٠' : '2,400',
		unit: '+',
	},
];
---

<section
	class='hero-section bg-ivory-50 overflow-hidden'
	style='padding: 72px 0 96px;'
>
	<div class='container mx-auto'>
		<div
			class='hero-grid'
			style='display:grid; grid-template-columns: 1.15fr 1fr; gap:64px; align-items:center;'
		>
			<!-- Text side -->
			<div>
				<!-- Eyebrow with line -->
				<div class='inline-flex items-center gap-2.5 mb-7'>
					<div class='w-8 h-px bg-teal-600'></div>
					<p class='h-eyebrow'>{strings.hero.label}</p>
				</div>
				<!-- Title — two-line with accent -->
				<h1
					class='font-display-ar font-medium text-navy-900 leading-none tracking-tight mb-7'
					style='font-size: clamp(44px, 5.2vw, 82px); line-height: 1.04; text-wrap: balance;'
				>
					{strings.hero.title1}<br />
					<span class='text-teal-700'>{strings.hero.title2}</span>
				</h1>
				<!-- Lede -->
				<p
					class='text-body-lg text-ink-700 leading-relaxed max-w-[48ch] mb-10'
					style='text-wrap: pretty;'
				>
					{strings.hero.subhead}
				</p>
				<!-- Actions -->
				<div class='flex flex-wrap gap-3.5'>
					<a href={`/${lang}/departments`} class='btn btn-primary'>
						{strings.hero.ctaPrimary}
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='h-4 w-4 rtl:rotate-180'
							viewBox='0 0 24 24'
							fill='none'
							stroke='currentColor'
							stroke-width='2.5'
							stroke-linecap='round'
							stroke-linejoin='round'
							aria-hidden='true'
							><polyline points='9 18 15 12 9 6'></polyline></svg
						>
					</a>
					<a href={`/${lang}/team`} class='btn btn-ghost'
						>{strings.hero.ctaSecondary}</a
					>
				</div>
				<!-- Since pill -->
				<div
					class='mt-10 flex items-center gap-4 p-4 bg-white border border-ink-100 rounded-full w-fit'
					style='box-shadow: 0 1px 2px rgba(15,59,61,0.04), 0 1px 3px rgba(15,59,61,0.06);'
				>
					<div class='font-display-ar text-3xl text-teal-700 font-medium lnum'>
						1959
					</div>
					<div class='text-[13px] text-ink-500 leading-snug'>
						{strings.hero.since}
					</div>
				</div>
			</div>

			<!-- Photo side -->
			<div class='relative aspect-[4/5] rounded-none overflow-hidden'>
				<div
					class='absolute inset-0 bg-gradient-to-br from-teal-900 via-teal-700 to-teal-600 flex items-end p-7'
				>
					<!-- Stripes overlay -->
					<div
						class='absolute inset-0'
						style='background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.04) 0, rgba(255,255,255,0.04) 2px, transparent 2px, transparent 14px)'
					>
					</div>
					<!-- Top badge -->
					<div class='absolute top-7 left-7 right-7 flex justify-between'>
						<div
							class='inline-flex gap-2 items-center px-3.5 py-2 bg-white/10 backdrop-blur border border-white/20 rounded-full text-white text-xs font-medium'
						>
							<span
								class='w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse-dot'
							></span>
							{isAr ? 'مفتوح الآن — استقبال الطوارئ' : 'Open now — ER intake'}
						</div>
					</div>
					<!-- Label -->
					<div
						class='font-mono text-white/55 text-xs tracking-wide relative z-10'
					>
						[ HERO_IMAGE &middot; facade-at-dusk.jpg &middot; 4:5 ]
					</div>
				</div>
			</div>
		</div>

		<!-- Stats rail -->
		<div
			class='hero-stat-rail mt-16 pt-10 border-t border-ink-200 grid grid-cols-4 gap-8'
		>
			{
				stats.map(s => (
					<div>
						<div class='font-display-ar font-medium text-4xl text-navy-900 leading-none lnum'>
							{s.value}
							{s.unit && (
								<span class='text-teal-600 text-[0.7em]'>{s.unit}</span>
							)}
						</div>
						<div class='text-[13px] text-ink-500 mt-2'>{s.label}</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	@media (max-width: 900px) {
		.hero-grid {
			grid-template-columns: 1fr !important;
			gap: 40px !important;
		}
		.hero-grid > div:last-child {
			order: -1;
			max-height: 320px;
			max-width: 320px;
			margin-inline: auto;
			width: 100%;
		}
		.hero-stat-rail {
			grid-template-columns: repeat(2, 1fr) !important;
			gap: 24px !important;
		}
	}
	@keyframes pulse-dot {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.4;
		}
	}
	.animate-pulse-dot {
		animation: pulse-dot 2s ease-in-out infinite;
	}
	/* English title uses display-en font with italic accent */
	:global(.lang-en) .hero-section h1 {
		font-family: var(--font-display-en, 'Fraunces', 'Georgia', serif);
		font-weight: 400;
		font-style: italic;
	}
	:global(.lang-en) .hero-section h1 span {
		font-style: normal;
	}
</style>
