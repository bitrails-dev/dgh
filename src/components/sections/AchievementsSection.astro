---
import { getCollection } from "astro:content";
import GoldHeading from "../ui/GoldHeading.astro";
import AchievementsTimeline from "./AchievementsTimeline.vue";
import AwardsWall from "./AwardsWall.astro";

const { lang, strings } = Astro.props;
const achievements = await getCollection("achievements");
const timelineItems = achievements
  .sort((a, b) => a.data.year - b.data.year)
  .map((entry) => ({
    year: entry.data.year,
    title: lang === "ar" ? entry.data.titleAr : entry.data.title,
    description: lang === "ar" ? entry.data.descriptionAr : entry.data.description,
  }));
---
<section id="achievements" class="bg-background py-20">
  <div class="container mx-auto">
    <GoldHeading text={strings.achievements.title} />
    <p class="mt-4 max-w-2xl text-sm text-muted">{strings.achievements.subtitle}</p>
    <div class="mt-10">
      <AchievementsTimeline items={timelineItems} client:visible />
    </div>
  </div>
</section>

<AwardsWall lang={lang} strings={strings} />
