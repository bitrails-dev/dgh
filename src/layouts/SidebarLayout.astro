---
import TheSidebar from '../components/layout/TheSidebar.vue';
import TheTopBar from '../components/layout/TheTopBar.astro';
import TheFooter from '../components/layout/TheFooter.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  lang: string;
  strings: any;
  breadcrumbs?: BreadcrumbItem[];
  currentPath: string;
}

const { lang, strings, breadcrumbs = [], currentPath } = Astro.props;

// Pass only what TheSidebar actually uses — avoids serialising the full i18n
// object (~5 KB) into every page's <astro-island> hydration payload.
const sidebarStrings = {
  site:    { name: strings.site?.name, established: strings.site?.established },
  nav:     strings.nav,
  sidebar: strings.sidebar,
  contact: { details: { emergencyNumber: strings.contact?.details?.emergencyNumber } },
};

// Only render breadcrumb strip on sub-pages (2+ items)
const showBreadcrumb = breadcrumbs.length >= 2;

// JSON-LD BreadcrumbList
const breadcrumbJsonLd = showBreadcrumb
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.label,
        ...(item.href ? { item: new URL(item.href, Astro.site ?? Astro.url.origin).href } : {}),
      })),
    })
  : null;
---

<TheTopBar lang={lang} strings={strings} />

<div class="flex flex-1">
  <TheSidebar lang={lang} currentPath={currentPath} strings={sidebarStrings} client:load />
  <main id="main-content" class="flex-1 min-w-0">
    {showBreadcrumb && (
      <div class="bg-ivory-50 px-6 lg:px-8 py-3">
        <nav aria-label="Breadcrumb" class="mx-auto flex max-w-[1440px] items-center">
          <ol class="flex flex-wrap items-center gap-1.5 text-xs text-ink-400">
            {breadcrumbs.map((item, index) => (
              <li class="flex items-center gap-1.5">
                {index > 0 && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-ink-300 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="9 18 15 12 9 6" />
                  </svg>
                )}
                {index < breadcrumbs.length - 1 && item.href ? (
                  <a href={item.href} class="hover:text-teal-700 transition-colors">{item.label}</a>
                ) : (
                  <span class="font-medium text-ink-600">{item.label}</span>
                )}
              </li>
            ))}
          </ol>
        </nav>
      </div>
    )}
    <slot />
  </main>
</div>

{breadcrumbJsonLd && (
  <script type="application/ld+json" set:html={breadcrumbJsonLd} />
)}

<TheFooter lang={lang} strings={strings} />
