---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  lang?: "ar" | "en";
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumbs?: { label: string; href?: string }[];
  currentPath?: string;
  strings?: any;
}

const {
  lang = "ar",
  title,
  description,
  ogImage = "/images/og-default.svg",
  noindex = false,
  breadcrumbs,
  currentPath = Astro.url.pathname,
  strings = {},
} = Astro.props;

const dir = lang === "ar" ? "rtl" : "ltr";
const locale = lang === "ar" ? "ar_EG" : "en_US";
const siteUrl = import.meta.env.SITE ?? "https://yourhospital.eg";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : new URL(ogImage, siteUrl).href;

// Tenant-driven identity for <head> (theme color, Schema.org org). Falls back to Dumyat literals
// when no tenant is resolved (single-tenant / unseeded). ponytail: openingHours + addressLocality
// stay literal for now — refine per-tenant later.
const tenant = Astro.locals.tenant;
const themeColor = tenant?.themeColor ?? "#15504f";
const orgName = tenant ? (lang === "ar" ? tenant.nameAr : tenant.name)
                       : (lang === "ar" ? "مستشفى دمياط العام" : "Dumyat Public Hospital");
const orgType = tenant?.type === "clinic" ? "MedicalClinic" : "Hospital";
const orgPhone = tenant?.contact?.phone ?? "+20-57-222-4340";
const orgLogo = tenant?.logo ?? `${siteUrl}/logo/logo-primary-on-IVORY.svg`;
---
<!doctype html>
<html lang={lang} dir={dir} class={lang === "ar" ? "font-body-ar" : "font-body-en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content={themeColor} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <ClientRouter />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo/logo-primary-on-IVORY.svg" />
    <link rel="apple-touch-icon" href="/logo/logo-primary-on-IVORY.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Reem+Kufi:wght@400;500;600;700&family=Fraunces:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Sans+Arabic:wght@400;500;600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org: Medical Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": orgType,
      "name": orgName,
      "url": siteUrl,
      "logo": orgLogo,
      "image": ogImageUrl,
      "description": description,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": lang === "ar" ? "دمياط" : "Dumyat",
        "addressCountry": "EG"
      },
      "telephone": orgPhone,
      "openingHours": ["Sa-Th 08:00-21:00", "Fr 09:00-18:00"],
      "sameAs": []
    })} />
  </head>
  <body class:list={["flex", "flex-col", "min-h-screen", "bg-ivory-50", "text-ink-900", lang === "ar" ? "" : "lang-en"]}>
    <!-- Skip to main content (accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:rounded-lg focus:bg-navy-900 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-ivory-50"
    >
      {lang === "ar" ? "تخطَّ إلى المحتوى" : "Skip to content"}
    </a>

    <slot />

    <!-- Back to top -->
    <button
      id="back-to-top"
      aria-label={lang === "ar" ? "العودة للأعلى" : "Back to top"}
      class="fixed bottom-6 end-6 z-40 hidden h-10 w-10 items-center justify-center rounded-full bg-navy-900 text-ivory-50 shadow-deep transition-all hover:bg-teal-800 focus:outline-none focus:ring-2 focus:ring-teal-600"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15" />
      </svg>
    </button>

    <script>
      function initScrollReveal() {
        const els = document.querySelectorAll('[data-animate="fade"]');
        if (!els.length) return;

        els.forEach((el) => {
          if (el.classList.contains('is-visible')) return;
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.15 }
          );
          observer.observe(el);
        });

        // Fallback: ensure elements in viewport become visible even if
        // the IntersectionObserver doesn't fire promptly (e.g. during View Transitions)
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            els.forEach((el) => {
              if (el.classList.contains('is-visible')) return;
              const rect = el.getBoundingClientRect();
              if (rect.top < window.innerHeight + 50 && rect.bottom > -50) {
                el.classList.add('is-visible');
              }
            });
          });
        });
      }

      let scrollHandler: (() => void) | null = null;

      function initBackToTop() {
        // Remove previous scroll handler to prevent listener accumulation
        if (scrollHandler) {
          window.removeEventListener('scroll', scrollHandler);
        }

        const btn = document.getElementById('back-to-top');
        if (!btn) return;

        // Clone to clear stale click listeners from previous page
        const fresh = btn.cloneNode(true) as HTMLElement;
        btn.replaceWith(fresh);

        scrollHandler = () => {
          if (window.scrollY > 400) {
            fresh.classList.remove('hidden');
            fresh.classList.add('flex');
          } else {
            fresh.classList.add('hidden');
            fresh.classList.remove('flex');
          }
        };
        window.addEventListener('scroll', scrollHandler, { passive: true });
        fresh.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      }

      // Runs on first load immediately, and again after every View Transition navigation
      initScrollReveal();
      initBackToTop();
      document.addEventListener('astro:page-load', () => {
        initScrollReveal();
        initBackToTop();
      });
    </script>
  </body>
</html>
