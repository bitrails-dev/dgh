---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import CardDepartment from '../../../components/ui/CardDepartment.astro';
import CardGrid from '../../../components/ui/CardGrid.astro';
import { getCollection } from 'astro:content';
import { getStrings, localePath } from '../../../i18n';
import type { Locale } from '../../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'en' } }];
}

const lang = (Astro.params.lang || "ar") as Locale;
const strings = getStrings(lang);
const breadcrumbs = [
  { label: strings.breadcrumb.home, href: localePath('/', lang) },
  { label: strings.breadcrumb.departments },
];

const departments = await getCollection('departments');
---
<BaseLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={localePath('/departments', lang)} title={`${strings.departments.title} | ${strings.site.name}`} description={strings.departments.subtitle}>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={localePath('/departments', lang)}>
    <div class="mx-auto max-w-[1440px] px-6 py-8">
      <PageHeader
        preTitle={strings.site.name}
        title={strings.departments.title}
        subtitle={strings.departments.subtitle}
      />
      <CardGrid cols={3} gap="none">
        {departments.map((dept) => (
          <CardDepartment
            dept={dept}
            lang={lang}
            centerLabel={strings.departments.centerOfExcellence}
            linkLabel={strings.links.viewDepartment}
          />
        ))}
      </CardGrid>
    </div>
  </SidebarLayout>
</BaseLayout>
