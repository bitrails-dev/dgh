---
import PortalLayout from "../../../../layouts/PortalLayout.astro";
import PortalSignUp from "../../../../components/portal/PortalSignUp.vue";
import { getStrings } from "../../../../i18n";
,
  { params: { lang: "en" } },
];

const lang = (Astro.params.lang || "ar") as "ar" | "en";
const strings = getStrings(lang);
---
<PortalLayout
  lang={lang}
  strings={strings}
  title={`${strings.portal.signUp.title} | ${strings.site.name}`}
  description={strings.portal.signUp.description}
>
  <PortalSignUp lang={lang} strings={strings} client:load />
</PortalLayout>
