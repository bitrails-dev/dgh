---
import PortalLayout from "../../../../layouts/PortalLayout.astro";
import PortalAppointments from "../../../../components/portal/PortalAppointments.vue";
import { getStrings } from "../../../../i18n";

const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);
---
<PortalLayout
  lang={lang}
  strings={strings}
  title={`${strings.portal.appointments.title} | ${strings.site.name}`}
  description={strings.portal.appointments.description}
>
  <PortalAppointments lang={lang} strings={strings} client:load />
</PortalLayout>
