---
import PortalLayout from "../../../../layouts/PortalLayout.astro";
import PortalSignIn from "../../../../components/portal/PortalSignIn.vue";
import { getStrings } from "../../../../i18n";

const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);
---
<PortalLayout
  lang={lang}
  strings={strings}
  title={`${strings.portal.signIn.title} | ${strings.site.name}`}
  description={strings.portal.signIn.description}
>
  <PortalSignIn lang={lang} strings={strings} client:load />
</PortalLayout>
