---
import PortalLayout from "../../../layouts/PortalLayout.astro";
import PortalHome from "../../../components/portal/PortalHome.vue";
import { getStrings } from "../../../i18n";

const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);
---
<PortalLayout
  lang={lang}
  strings={strings}
  title={`${strings.portal.title} | ${strings.site.name}`}
  description={strings.portal.description}
>
  <PortalHome lang={lang} strings={strings} client:load />
</PortalLayout>
