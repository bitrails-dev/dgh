---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import FilteredCardGrid from '../../../components/ui/FilteredCardGrid.vue';
import { getCollection } from '../../../lib/cms';
import { getStrings, localePath } from '../../../i18n';

const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);

const allArticles = (await getCollection('articles')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = [
  { value: 'hospital-news', labelEn: 'Hospital News', labelAr: 'أخبار المستشفى' },
  { value: 'health-tips', labelEn: 'Health Tips', labelAr: 'نصائح صحية' },
  { value: 'research', labelEn: 'Research', labelAr: 'الأبحاث' },
  { value: 'events', labelEn: 'Events', labelAr: 'الفعاليات' },
];

const items = allArticles.map((article) => ({
  id: article.id,
  slug: article.id,
  title: article.data.title,
  titleAr: article.data.titleAr,
  category: article.data.category,
  thumbnail: article.data.thumbnail,
  date: article.data.date.toISOString(),
  summary: '',
  summaryAr: '',
}));

const breadcrumbs = [
  { label: strings.breadcrumb.home, href: localePath('/', lang) },
  { label: lang === 'ar' ? 'المقالات' : 'Articles' },
];
---

<BaseLayout
  lang={lang}
  strings={strings}
  breadcrumbs={breadcrumbs}

  title={`${lang === 'ar' ? 'المقالات' : 'Articles'} | ${strings.site.name}`}
  description={lang === 'ar' ? 'اقرأ أحدث المقالات الطبية والأخبار من مستشفانا' : 'Read the latest medical articles and news from our hospital'}
>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs}>
    <div class="mx-auto max-w-[1440px] px-6 pt-8">
      <PageHeader
        title={lang === 'ar' ? 'المقالات' : 'Articles'}
        subtitle={lang === 'ar' ? 'أحدث المقالات الطبية والمعلومات الصحية' : 'Latest medical articles and health information'}
      />
    </div>

    <section class="mx-auto max-w-[1440px] px-6 pb-12">
      <FilteredCardGrid
        client:visible
        items={items}
        categories={categories}
        lang={lang}
        basePath={localePath('/articles', lang)}
        itemsPerPage={8}
        cardType="article"
      />
    </section>
  </SidebarLayout>
</BaseLayout>
