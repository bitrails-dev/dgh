---
import ShopLayout from "../../../layouts/ShopLayout.astro";
import { getStrings } from "../../../i18n";
import ShopCatalog from "../../../components/shop/ShopCatalog.vue";

// Catalog list (Wave E3). The grid is a client-hydrated island that reads the signed store catalog
// via shopApi (same-origin /api/store/v2/catalog → Astro gateway proxy → CMS plugin store). The
// Astro proxy resolves the tenant + signs; this page stays seam-free and never imports store/server.
const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);
---
<ShopLayout lang={lang} strings={strings} title={`${strings.shop.title} | ${strings.site.name}`} description={strings.shop.description}>
  <ShopCatalog lang={lang} strings={strings} client:load />
</ShopLayout>
