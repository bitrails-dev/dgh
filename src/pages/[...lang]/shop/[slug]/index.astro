---
import ShopLayout from "../../../../layouts/ShopLayout.astro";
import { getStrings, localePath } from "../../../../i18n";
import { cmsFetch, storeTenantSlug, ensureCsrf } from "../../../../lib/store/server";
import { formatMoney } from "../../../../lib/store/money";
import ProductBuy from "../../../../components/shop/ProductBuy.vue";

const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);
ensureCsrf(Astro.cookies);

const slug = storeTenantSlug(Astro.locals);
const idOrSlug = Astro.params.slug as string;
let product: any = null;
if (slug && idOrSlug) {
  try {
    const r = await cmsFetch(slug, `/products/${encodeURIComponent(idOrSlug)}`);
    if (r.ok) product = await r.json();
  } catch {
    /* not found */
  }
}
---
<ShopLayout lang={lang} strings={strings} title={product ? `${product.name} | ${strings.shop.title}` : strings.shop.title} description={product?.description || strings.shop.description}>
  {product ? (
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        {product.images?.[0]?.url ? (
          <img src={product.images[0].url} alt={product.name} class="w-full rounded-2xl bg-ivory-100 object-cover" />
        ) : (
          <div class="w-full aspect-square rounded-2xl bg-ivory-100"></div>
        )}
      </div>
      <div>
        <h1 class="font-display-ar text-3xl font-bold text-navy-900">{product.name}</h1>
        <p class="text-2xl text-teal-700 font-bold mt-2">{formatMoney(product.price)}</p>
        {product.description && <p class="text-ink-600 mt-4 leading-relaxed">{product.description}</p>}
        <ProductBuy lang={lang} strings={strings} product={product} client:load />
      </div>
    </div>
  ) : (
    <div class="text-center py-16">
      <p class="text-ink-500 mb-4">{strings.shop.product.notFound}</p>
      <a href={localePath("/shop", lang)} class="btn btn-teal">{strings.shop.cart.continueShopping}</a>
    </div>
  )}
</ShopLayout>
