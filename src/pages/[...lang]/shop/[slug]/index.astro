---
import ShopLayout from "../../../../layouts/ShopLayout.astro";
import { getStrings } from "../../../../i18n";
import ProductDetail from "../../../../components/shop/ProductDetail.vue";

// Product detail (Wave E3). The product is fetched client-side via shopApi.product(slug); this page
// is a seam-free shell that just forwards the slug param to the island.
const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);
const slug = (Astro.params.slug ?? "") as string;
---
<ShopLayout lang={lang} strings={strings} title={`${strings.shop.title} | ${strings.site.name}`} description={strings.shop.description}>
  <ProductDetail lang={lang} strings={strings} slug={slug} client:load />
</ShopLayout>
