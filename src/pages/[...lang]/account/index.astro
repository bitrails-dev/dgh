---
import ShopLayout from "../../../layouts/ShopLayout.astro";
import { getStrings } from "../../../i18n";
import AccountView from "../../../components/shop/AccountView.vue";

// Account (Wave E3). Sign-in / register / logout / me + live order history via shopApi.auth + shopApi.orders.
const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);
---
<ShopLayout lang={lang} strings={strings} title={`${strings.shop.account.title} | ${strings.site.name}`} description={strings.shop.account.title}>
  <AccountView lang={lang} strings={strings} client:load />
</ShopLayout>
