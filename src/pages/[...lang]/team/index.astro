---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import CardBase from '../../../components/ui/CardBase.astro';
import CardDoctor from '../../../components/ui/CardDoctor.astro';
import CardGrid from '../../../components/ui/CardGrid.astro';
import { getCollection } from 'astro:content';
import { getStrings, localePath } from '../../../i18n';
import type { Locale } from '../../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'en' } }];
}

const lang = (Astro.params.lang || "ar") as Locale;
const strings = getStrings(lang);
const breadcrumbs = [
  { label: strings.breadcrumb.home, href: localePath('/', lang) },
  { label: strings.breadcrumb.team },
];

const doctors = await getCollection('doctors');
const sortByOrder = (a: any, b: any) => (a.data.order ?? 999) - (b.data.order ?? 999);
const featured = doctors.filter((d) => d.data.featured).sort(sortByOrder);
const others = doctors.filter((d) => !d.data.featured).sort(sortByOrder);
---
<BaseLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} title={`${strings.team.title} | ${strings.site.name}`} description={strings.team.subtitle}>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs}>
    <div class="mx-auto max-w-[1440px] px-6 py-8">
      <PageHeader
        preTitle={strings.site.name}
        title={strings.team.title}
        subtitle={strings.team.subtitle}
      />

      {featured.length > 0 && (
        <section class="mb-12">
          <h2 class="mb-6 text-lg font-bold text-ink-900">{strings.team.featuredTitle}</h2>
          <CardGrid cols={3} gap="md">
            {featured.map((doctor) => {
              const name = lang === 'ar' ? doctor.data.nameAr : doctor.data.name;
              const specialty = lang === 'ar' ? doctor.data.specialtyAr : doctor.data.specialty;
              const bio = lang === 'ar' ? doctor.data.bioAr : doctor.data.bio;
              const imageBadge = doctor.data.certified
                ? { label: strings.team.certified, iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' }
                : undefined;
              return (
                <CardBase
                  href={localePath(`/doctors/${doctor.id}`, lang)}
                  image={doctor.data.photo}
                  imageAlt={name}
                  title={name}
                  preTitle={specialty}
                  description={bio}
                  ctaLabel={`${strings.team.profileLabel} →`}
                  imageBadge={imageBadge}
                  imageHeight="h-96"
                />
              );
            })}
          </CardGrid>
        </section>
      )}

      {others.length > 0 && (
        <section>
          <h2 class="mb-6 text-lg font-bold text-ink-900">{strings.team.doctorsTitle}</h2>
          <CardGrid cols={2} gap="md">
            {others.map((doctor) => (
              <CardDoctor
                doctor={doctor}
                lang={lang}
                certifiedLabel={strings.team.certified}
                profileLabel={strings.team.profileLabel}
                imageAlt={lang === 'ar' ? doctor.data.nameAr : doctor.data.name}
              />
            ))}
          </CardGrid>
        </section>
      )}
    </div>
  </SidebarLayout>
</BaseLayout>
