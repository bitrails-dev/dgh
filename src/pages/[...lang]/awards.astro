---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import AwardsWall from '../../components/sections/AwardsWall.astro';
import { getStrings, localePath } from '../../i18n';
import type { Locale } from '../../i18n';

const lang = (Astro.params.lang || "ar") as Locale;
const strings = getStrings(lang);
const breadcrumbs = [
  { label: strings.breadcrumb.home, href: localePath('/', lang) },
  { label: strings.breadcrumb.awards },
];
---
<BaseLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} title={`${strings.achievements.awardsTitle} | ${strings.site.name}`} description={strings.achievements.subtitle}>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs}>
    <div class="mx-auto max-w-[1440px] px-6 py-8">
      <PageHeader title={strings.achievements.awardsTitle} />
      <AwardsWall lang={lang} strings={strings} />
    </div>
  </SidebarLayout>
</BaseLayout>
