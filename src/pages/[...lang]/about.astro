---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import { getStrings, localePath } from '../../i18n';
import type { Locale } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'en' } }];
}

const lang = (Astro.params.lang || "ar") as Locale;
const strings = getStrings(lang);
const breadcrumbs = [
  { label: strings.breadcrumb.home, href: localePath('/', lang) },
  { label: strings.breadcrumb.about },
];
---
<BaseLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} title={`${strings.nav.about} | ${strings.site.name}`} description={strings.mission.missionBody}>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs}>
    <div class="mx-auto max-w-[1440px] px-6 py-8">
      <PageHeader title={strings.nav.about} subtitle={strings.mission.missionBody} />

      <!-- Mission, Vision, Values grid -->
      <div class="bg-ink-200 border border-ink-200" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;">
        <!-- Mission card -->
        <div class="bg-ivory-50 p-7 transition-colors duration-200 hover:bg-white">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-teal-700/10">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-teal-700" aria-hidden="true">
              <path d="M12 2l8 4v6c0 5-3.5 9.7-8 12-4.5-2.3-8-7-8-12V6l8-4z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h2 class="text-label uppercase tracking-widest text-teal-700 font-medium">{strings.mission.missionTitle}</h2>
          <p class="mt-3 text-sm text-ink-500 leading-relaxed">{strings.mission.missionBody}</p>
        </div>

        <!-- Vision card -->
        <div class="bg-ivory-50 p-7 transition-colors duration-200 hover:bg-white">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-teal-700/10">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-teal-700" aria-hidden="true">
              <path d="M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z M12 9a3 3 0 100 6 3 3 0 000-6z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h2 class="text-label uppercase tracking-widest text-teal-700 font-medium">{strings.mission.visionTitle}</h2>
          <p class="mt-3 text-sm text-ink-500 leading-relaxed">{strings.mission.visionBody}</p>
        </div>

        <!-- Values card -->
        <div class="bg-ivory-50 p-7 transition-colors duration-200 hover:bg-white">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-teal-700/10">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-teal-700" aria-hidden="true">
              <path d="M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h2 class="text-label uppercase tracking-widest text-teal-700 font-medium">{strings.mission.valuesTitle}</h2>
          <p class="mt-3 text-sm text-ink-500 leading-relaxed">{strings.mission.valuesBody}</p>
        </div>
      </div>
    </div>
  </SidebarLayout>
  <style>
    @media (max-width: 900px) {
      div[style*="grid-template-columns: repeat(3, 1fr)"] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</BaseLayout>
