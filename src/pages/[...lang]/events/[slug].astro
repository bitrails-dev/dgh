---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import ArRedirect from '../../../components/ui/ArRedirect.astro';
import YouTubeEmbed from '../../../components/ui/YouTubeEmbed.astro';
import ImageGallery from '../../../components/ui/ImageGallery.vue';
import { getCollection } from 'astro:content';
import { getStrings, localePath } from '../../../i18n';

export async function getStaticPaths() {
  const events = await getCollection('events');
  const langs = [undefined, 'en', 'ar'] as const;
  return events.flatMap((event) =>
    langs.map((lang) => ({
      params: { lang, slug: event.id },
      props: { event },
    }))
  );
}

const lang = (Astro.params.lang || "ar") as "ar" | "en";
const isArRedirect = Astro.params.lang === 'ar';
const { event } = Astro.props;
const strings = getStrings(lang);

const title = lang === 'ar' ? event.data.titleAr : event.data.title;
const summary = lang === 'ar' ? event.data.summaryAr : event.data.summary;
const body = lang === 'ar' ? event.data.bodyAr : event.data.body;

const categoryColors: Record<string, string> = {
  procedure: 'bg-teal-700/10 text-teal-700',
  event: 'bg-navy-900/10 text-navy-900',
  announcement: 'bg-gold/15 text-gold',
};

const categoryLabels: Record<string, { en: string; ar: string }> = {
  procedure: { en: 'Procedure', ar: 'إجراء' },
  event: { en: 'Event', ar: 'حدث' },
  announcement: { en: 'Announcement', ar: 'إعلان' },
};

const formatDate = (dateStr: string | Date) =>
  new Date(dateStr).toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });

const categoryLabel = categoryLabels[event.data.category]?.[lang === 'ar' ? 'ar' : 'en'] || '';

const breadcrumbs = [
  { label: strings.breadcrumb.home, href: localePath('/', lang) },
  { label: lang === 'ar' ? 'الفعاليات' : 'Events', href: localePath('/events', lang) },
  { label: title },
];

const galleryImages = event.data.gallery?.map((img) => ({
  url: img.url,
  caption: lang === 'ar' ? img.captionAr || img.caption : img.caption,
  captionAr: img.captionAr,
  alt: img.alt,
})) || [];
---

{isArRedirect ? (
  <ArRedirect url={`/events/${Astro.params.slug}`} />
) : (
<BaseLayout
  lang={lang}
  strings={strings}
  breadcrumbs={breadcrumbs}
  title={`${title} | ${strings.site.name}`}
  description={summary}
>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs}>

    <!-- Page header -->
    <section class="mx-auto max-w-[1440px] px-6 pt-12 pb-2" data-animate="fade">
      <div class="inline-flex items-center gap-2.5 mb-5">
        <div class="w-8 h-px bg-teal-600"></div>
        <p class="h-eyebrow">{lang === 'ar' ? 'الفعاليات' : 'Events'}</p>
      </div>
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold ${categoryColors[event.data.category] || 'bg-ink-500/10 text-ink-500'}`}>
          {categoryLabel}
        </span>
        <time class="text-sm text-ink-400">{formatDate(event.data.date)}</time>
      </div>
      <h1 class="font-display-ar font-medium text-navy-900 leading-none tracking-tight" style="font-size: clamp(36px, 4vw, 56px); line-height: 1.1;">{title}</h1>
      {summary && <p class="mt-4 max-w-2xl text-body text-ink-500">{summary}</p>}
    </section>

    <!-- Main content -->
    <section class="mx-auto max-w-[1440px] px-6 py-10">
      <div class="grid gap-8 lg:grid-cols-3">
        <!-- Main column -->
        <div class="lg:col-span-2 space-y-8">
          {event.data.thumbnail && (
            <div class="overflow-hidden border border-ink-100">
              <img src={event.data.thumbnail} alt={title} class="w-full h-96 object-cover" />
            </div>
          )}

          {body && (
            <div class="bg-ivory-50 p-8 border border-ink-100">
              <div class="prose max-w-none">
                <div set:html={body} />
              </div>
            </div>
          )}

          {event.data.youtubeUrl && (
            <div class="overflow-hidden border border-ink-100">
              <YouTubeEmbed url={event.data.youtubeUrl} />
            </div>
          )}

          {galleryImages.length > 0 && (
            <div class="space-y-4">
              <h2 class="text-lg font-bold text-ink-900 font-display-ar">
                {lang === 'ar' ? 'معرض الصور' : 'Photo Gallery'}
              </h2>
              <ImageGallery images={galleryImages} lang={lang} client:visible />
            </div>
          )}

          <div>
            <a href={localePath('/events', lang)} class="btn-text text-sm">
              <span class="inline-flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                {lang === 'ar' ? 'العودة إلى الفعاليات' : 'Back to Events'}
              </span>
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-teal-800 p-8 text-ivory-50 shadow-deep">
            <h3 class="text-lg font-bold font-display-ar mb-4">
              {lang === 'ar' ? 'معلومات الفعالية' : 'Event Details'}
            </h3>
            <div class="space-y-4">
              <div>
                <p class="text-xs text-ivory-100/60">{lang === 'ar' ? 'التاريخ' : 'Date'}</p>
                <p class="mt-1 font-semibold">{formatDate(event.data.date)}</p>
              </div>
              <div>
                <p class="text-xs text-ivory-100/60">{lang === 'ar' ? 'النوع' : 'Category'}</p>
                <p class="mt-1 font-semibold">{categoryLabel}</p>
              </div>
            </div>
            <a href={localePath('/contact', lang)} class="btn btn-teal mt-6 w-full justify-center">
              {lang === 'ar' ? 'تسجيل الاهتمام' : 'Register Interest'}
            </a>
          </div>

          <div class="bg-ivory-50 p-6 border border-ink-100 text-sm text-ink-500">
            <p class="font-semibold text-ink-900 mb-2">{lang === 'ar' ? 'خط الطوارئ' : 'Emergency Line'}</p>
            <a href="tel:12345" class="text-2xl font-extrabold text-coral hover:underline">12345</a>
            <p class="mt-1 text-xs text-ink-400">{lang === 'ar' ? 'متاح على مدار الساعة' : 'Available 24/7'}</p>
          </div>
        </div>
      </div>
    </section>

  </SidebarLayout>
</BaseLayout>
)}
