---
import ShopLayout from "../../../layouts/ShopLayout.astro";
import { getStrings } from "../../../i18n";
import CheckoutForm from "../../../components/shop/CheckoutForm.vue";

// Checkout (Wave E3). Submits the plugin-first v2 payload via shopApi.checkout (cartId +
// paymentMethod + shippingAddress + …); the Astro proxy signs + forwards to the CMS signed checkout
// endpoint. COD/bank finish inline; Paymob/Kashier redirect to the hosted checkout URL.
const lang: "ar" | "en" = Astro.params.lang === "en" ? "en" : "ar";
const strings = getStrings(lang);
---
<ShopLayout lang={lang} strings={strings} title={`${strings.shop.checkout.title} | ${strings.site.name}`} description={strings.shop.checkout.title}>
  <CheckoutForm lang={lang} strings={strings} client:load />
</ShopLayout>
