---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import FilteredCardGrid from '../../../components/ui/FilteredCardGrid.vue';
import { getCollection } from 'astro:content';
import { getStrings } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'ar' } },
    { params: { lang: 'en' } },
  ];
}

const lang = Astro.params.lang as 'ar' | 'en';
const strings = getStrings(lang);

const allEvents = (await getCollection('events')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = [
  { value: 'procedure', labelEn: 'Procedure', labelAr: 'إجراء' },
  { value: 'event', labelEn: 'Event', labelAr: 'حدث' },
  { value: 'announcement', labelEn: 'Announcement', labelAr: 'إعلان' },
];

const items = allEvents.map((event) => ({
  id: event.id,
  slug: event.id,
  title: event.data.title,
  titleAr: event.data.titleAr,
  category: event.data.category,
  thumbnail: event.data.thumbnail,
  date: event.data.date.toISOString(),
  summary: event.data.summary,
  summaryAr: event.data.summaryAr,
}));

const breadcrumbs = [
  { label: strings.breadcrumb.home, href: `/${lang}/` },
  { label: lang === 'ar' ? 'الفعاليات' : 'Events' },
];
---

<BaseLayout
  lang={lang}
  strings={strings}
  breadcrumbs={breadcrumbs}
  currentPath={`/${lang}/events`}
  title={`${lang === 'ar' ? 'الفعاليات' : 'Events'} | ${strings.site.name}`}
  description={lang === 'ar' ? 'اكتشف فعاليات المستشفى وأحدث الأخبار الطبية' : 'Discover hospital events and latest medical news'}
>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={`/${lang}/events`}>
    <PageHeader
      title={lang === 'ar' ? 'الفعاليات' : 'Events'}
      subtitle={lang === 'ar' ? 'تابع أحدث فعاليات المستشفى والبرامج الطبية' : 'Stay updated with hospital events and medical programs'}
    />

    <section class="container mx-auto px-4 py-12">
      <FilteredCardGrid
        client:visible
        items={items}
        categories={categories}
        lang={lang}
        basePath={`/${lang}/events`}
        itemsPerPage={8}
        cardType="event"
      />
    </section>
  </SidebarLayout>
</BaseLayout>
