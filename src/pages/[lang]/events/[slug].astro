---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import YouTubeEmbed from '../../../components/ui/YouTubeEmbed.astro';
import ImageGallery from '../../../components/ui/ImageGallery.vue';
import WaveDivider from '../../../components/layout/WaveDivider.astro';
import { getCollection } from 'astro:content';
import { getStrings } from '../../../i18n';

export async function getStaticPaths() {
  const events = await getCollection('events');
  const langs = ['ar', 'en'];
  return events.flatMap((event) =>
    langs.map((lang) => ({
      params: { lang, slug: event.id },
      props: { event },
    }))
  );
}

const { lang } = Astro.params;
const { event } = Astro.props;
const strings = getStrings(lang);

const title = lang === 'ar' ? event.data.titleAr : event.data.title;
const summary = lang === 'ar' ? event.data.summaryAr : event.data.summary;
const body = lang === 'ar' ? event.data.bodyAr : event.data.body;

const categoryColors: Record<string, string> = {
  procedure: 'bg-secondary/10 text-secondary',
  event: 'bg-primary/10 text-primary',
  announcement: 'bg-accent/15 text-accent',
};

const categoryLabels: Record<string, { en: string; ar: string }> = {
  procedure: { en: 'Procedure', ar: 'إجراء' },
  event: { en: 'Event', ar: 'حدث' },
  announcement: { en: 'Announcement', ar: 'إعلان' },
};

const formatDate = (dateStr: string | Date) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const categoryLabel = categoryLabels[event.data.category]?.[lang === 'ar' ? 'ar' : 'en'] || '';

const breadcrumbs = [
  { label: strings.breadcrumb.home, href: `/${lang}/` },
  { label: lang === 'ar' ? 'الفعاليات' : 'Events', href: `/${lang}/events` },
  { label: title },
];

const galleryImages = event.data.gallery?.map((img) => ({
  url: img.url,
  caption: lang === 'ar' ? img.captionAr || img.caption : img.caption,
  captionAr: img.captionAr,
  alt: img.alt,
})) || [];
---

<BaseLayout
  lang={lang}
  strings={strings}
  breadcrumbs={breadcrumbs}
  currentPath={`/${lang}/events/${event.id}`}
  title={`${title} | ${strings.site.name}`}
  description={summary}
>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={`/${lang}/events/${event.id}`}>
    <!-- Hero banner -->
    <section class="bg-gradient-to-br from-primary/90 to-secondary/90 text-white section-stripes py-16">
      <div class="px-6">
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ${categoryColors[event.data.category] || 'bg-muted/10 text-muted'}`}>
              {categoryLabel}
            </span>
            <time class="text-sm text-white/70">{formatDate(event.data.date)}</time>
          </div>
          <h1 class="text-4xl font-extrabold leading-tight">{title}</h1>
          <p class="max-w-2xl text-base text-white/80">{summary}</p>
        </div>
      </div>
    </section>

    <WaveDivider class="text-background" />

    <!-- Main content -->
    <section class="px-6 py-12">
      <div class="grid gap-8 lg:grid-cols-3">
        <!-- Main column -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Thumbnail -->
          {event.data.thumbnail && (
            <div class="rounded-2xl overflow-hidden shadow-soft">
              <img
                src={event.data.thumbnail}
                alt={title}
                class="w-full h-96 object-cover"
              />
            </div>
          )}

          <!-- Body content -->
          {body && (
            <div class="rounded-2xl bg-surface p-8 shadow-soft">
              <div class="prose prose-sm dark:prose-invert max-w-none">
                <div set:html={body} />
              </div>
            </div>
          )}

          <!-- YouTube embed -->
          {event.data.youtubeUrl && (
            <div class="rounded-2xl overflow-hidden shadow-soft">
              <YouTubeEmbed url={event.data.youtubeUrl} />
            </div>
          )}

          <!-- Gallery -->
          {galleryImages.length > 0 && (
            <div class="space-y-4">
              <h2 class="text-lg font-bold text-text">
                {lang === 'ar' ? 'معرض الصور' : 'Photo Gallery'}
              </h2>
              <ImageGallery images={galleryImages} lang={lang} client:visible />
            </div>
          )}

          <!-- Back link -->
          <div>
            <a
              href={`/${lang}/events`}
              class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              {lang === 'ar' ? 'العودة إلى الفعاليات' : 'Back to Events'}
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Event info card -->
          <div class="rounded-2xl bg-primary p-8 text-white shadow-deep">
            <h3 class="text-lg font-bold mb-4">
              {lang === 'ar' ? 'معلومات الفعالية' : 'Event Details'}
            </h3>

            <div class="space-y-4">
              <div>
                <p class="text-xs text-white/60">{lang === 'ar' ? 'التاريخ' : 'Date'}</p>
                <p class="mt-1 font-semibold">{formatDate(event.data.date)}</p>
              </div>

              <div>
                <p class="text-xs text-white/60">{lang === 'ar' ? 'النوع' : 'Category'}</p>
                <p class="mt-1 font-semibold">{categoryLabel}</p>
              </div>
            </div>

            <a
              href={`/${lang}/contact`}
              class="mt-6 flex items-center justify-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-primary shadow-soft transition-transform hover:-translate-y-0.5"
            >
              {lang === 'ar' ? 'تسجيل الاهتمام' : 'Register Interest'}
            </a>
          </div>

          <!-- Emergency contact -->
          <div class="rounded-2xl bg-surface p-6 shadow-soft text-sm text-muted">
            <p class="font-semibold text-text mb-2">{lang === 'ar' ? 'خط الطوارئ' : 'Emergency Line'}</p>
            <a href="tel:12345" class="text-2xl font-extrabold text-red-600 hover:underline">12345</a>
            <p class="mt-1 text-xs text-muted/70">{lang === 'ar' ? 'متاح على مدار الساعة' : 'Available 24/7'}</p>
          </div>
        </div>
      </div>
    </section>

  </SidebarLayout>
</BaseLayout>
