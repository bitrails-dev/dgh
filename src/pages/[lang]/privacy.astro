---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SidebarLayout from "../../layouts/SidebarLayout.astro";
import WaveDivider from "../../components/layout/WaveDivider.astro";
import { getStrings } from "../../i18n";

export const getStaticPaths = () => [
  { params: { lang: "ar" } },
  { params: { lang: "en" } },
];

const { lang } = Astro.params;
const strings = getStrings(lang);
const isAr = lang === "ar";

const breadcrumbs = [
  { label: strings.breadcrumb.home, href: `/${lang}/` },
  { label: isAr ? "سياسة الخصوصية" : "Privacy Policy" },
];
---

<BaseLayout
  lang={lang}
  strings={strings}
  title={`${isAr ? "سياسة الخصوصية" : "Privacy Policy"} — ${strings.site.name}`}
  description={isAr ? "سياسة الخصوصية لموقع مستشفى دمياط العام" : "Privacy Policy for Dumyat Public Hospital website"}
  breadcrumbs={breadcrumbs}
  currentPath={`/${lang}/privacy`}
>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={`/${lang}/privacy`}>
    <section class="bg-primary text-white section-stripes py-20">
      <div class="px-6">
        <h1 class="text-4xl font-extrabold">{isAr ? "سياسة الخصوصية" : "Privacy Policy"}</h1>
      </div>
    </section>

    <WaveDivider class="text-background" />

    <section class="px-6 py-12">
      <div class="mx-auto max-w-3xl rounded-2xl bg-surface p-10 shadow-soft prose prose-sm max-w-none" data-animate="fade">
        {isAr ? (
          <div dir="rtl" class="space-y-6 text-sm leading-relaxed text-muted">
            <p class="text-xs text-muted/70">آخر تحديث: {new Date().toLocaleDateString("ar-EG", { year: "numeric", month: "long", day: "numeric" })}</p>
            <h2 class="text-lg font-bold text-text">جمع المعلومات</h2>
            <p>يجمع الموقع معلومات أساسية فقط عند تواصلك معنا عبر النموذج الإلكتروني، وتشمل: الاسم ورقم الهاتف ومضمون الرسالة. لا يتم تخزين هذه البيانات على خوادمنا؛ إذ تُرسَل مباشرةً عبر تطبيق واتساب.</p>

            <h2 class="text-lg font-bold text-text">ملفات الارتباط (Cookies)</h2>
            <p>لا يستخدم الموقع ملفات تتبع أو إعلانات. قد يستخدم الخرائط المضمّنة (Google Maps) ملفات ارتباط خاصة بها وفق سياسة خصوصية Google.</p>

            <h2 class="text-lg font-bold text-text">مشاركة البيانات</h2>
            <p>لا تُشارك مستشفى دمياط العام بياناتك مع أي جهة خارجية ولا تبيعها. المعلومات المُرسَلة عبر واتساب تخضع لسياسة خصوصية Meta/WhatsApp.</p>

            <h2 class="text-lg font-bold text-text">حقوقك</h2>
            <p>لك الحق في طلب حذف بيانات الاتصال بك من خلال التواصل معنا عبر البريد الإلكتروني.</p>

            <h2 class="text-lg font-bold text-text">التعديلات</h2>
            <p>نحتفظ بحق تعديل هذه السياسة في أي وقت. يُرجى مراجعتها بشكل دوري.</p>
          </div>
        ) : (
          <div class="space-y-6 text-sm leading-relaxed text-muted">
            <p class="text-xs text-muted/70">Last Updated: {new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
            <h2 class="text-lg font-bold text-text">Information Collection</h2>
            <p>We collect basic information only when you contact us through the contact form, including: name, phone number, and message content. This data is not stored on our servers; it is sent directly via WhatsApp.</p>

            <h2 class="text-lg font-bold text-text">Cookies</h2>
            <p>The website does not use tracking or advertising cookies. Embedded maps (Google Maps) may use cookies according to Google's privacy policy.</p>

            <h2 class="text-lg font-bold text-text">Data Sharing</h2>
            <p>Dumyat Public Hospital does not share or sell your data to any third party. Information sent via WhatsApp is subject to Meta/WhatsApp's privacy policy.</p>

            <h2 class="text-lg font-bold text-text">Your Rights</h2>
            <p>You have the right to request deletion of your contact information by contacting us via email.</p>

            <h2 class="text-lg font-bold text-text">Changes</h2>
            <p>We reserve the right to modify this policy at any time. Please review it periodically.</p>
          </div>
        )}
      </div>
    </section>

  </SidebarLayout>
</BaseLayout>
