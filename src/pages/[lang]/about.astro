---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import { getStrings } from '../../i18n';
import type { Locale } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'ar' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Locale;
const strings = getStrings(lang);
const breadcrumbs = [
  { label: strings.breadcrumb.home, href: `/${lang}/` },
  { label: strings.breadcrumb.about },
];
---
<BaseLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={`/${lang}/about`} title={`${strings.nav.about} | ${strings.site.name}`} description={strings.mission.missionBody}>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={`/${lang}/about`}>
    <div class="px-6 py-8">
      <PageHeader title={strings.nav.about} subtitle={strings.mission.missionBody} />

      <!-- Mission, Vision, Values grid -->
      <div class="grid gap-6 lg:grid-cols-3">
        <!-- Mission card -->
        <div class="relative rounded-2xl bg-surface p-7 shadow-soft hover:shadow-layered transition-shadow duration-300">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-primary" aria-hidden="true">
              <path d="M12 2l8 4v6c0 5-3.5 9.7-8 12-4.5-2.3-8-7-8-12V6l8-4z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h2 class="text-label uppercase tracking-widest text-accent font-semibold">{strings.mission.missionTitle}</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">{strings.mission.missionBody}</p>
        </div>

        <!-- Vision card -->
        <div class="relative rounded-2xl bg-surface p-7 shadow-soft hover:shadow-layered transition-shadow duration-300">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-primary" aria-hidden="true">
              <path d="M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z M12 9a3 3 0 100 6 3 3 0 000-6z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h2 class="text-label uppercase tracking-widest text-accent font-semibold">{strings.mission.visionTitle}</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">{strings.mission.visionBody}</p>
        </div>

        <!-- Values card -->
        <div class="relative rounded-2xl bg-surface p-7 shadow-soft hover:shadow-layered transition-shadow duration-300">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-primary" aria-hidden="true">
              <path d="M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h2 class="text-label uppercase tracking-widest text-accent font-semibold">{strings.mission.valuesTitle}</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">{strings.mission.valuesBody}</p>
        </div>
      </div>
    </div>
  </SidebarLayout>
</BaseLayout>
