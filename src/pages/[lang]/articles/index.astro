---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TheNavbar from "../../../components/layout/TheNavbar.vue";
import TheFooter from "../../../components/layout/TheFooter.astro";
import WaveDivider from "../../../components/layout/WaveDivider.astro";
import CardNews from "../../../components/ui/CardNews.astro";
import { getCollection } from "astro:content";
import { getStrings } from "../../../i18n";

export const getStaticPaths = () => [
  { params: { lang: "ar" } },
  { params: { lang: "en" } },
];

const { lang } = Astro.params;
const strings = getStrings(lang);
const basePath = `/${lang}`;

const allArticles = (await getCollection("articles"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ["hospital-news", "health-tips", "research", "events"] as const;
---
<BaseLayout
  lang={lang}
  title={`${lang === "ar" ? "المقالات" : "Articles"} — ${strings.site.name}`}
  description={strings.news.subtitle}
>
  <TheNavbar lang={lang} strings={strings} client:load />

  <!-- Hero banner -->
  <section class="bg-primary text-white section-stripes py-20">
    <div class="container mx-auto">
      <nav aria-label="breadcrumb" class="mb-6 flex items-center gap-2 text-xs text-white/60">
        <a href={`${basePath}/`} class="hover:text-accent transition-colors">{strings.site.name}</a>
        <span aria-hidden="true">/</span>
        <span class="text-white/90">{lang === "ar" ? "المقالات" : "Articles"}</span>
      </nav>
      <h1 class="text-4xl font-extrabold">{lang === "ar" ? "المقالات الطبية" : "Medical Articles"}</h1>
      <p class="mt-3 max-w-2xl text-sm text-white/70">{strings.news.subtitle}</p>
    </div>
  </section>

  <WaveDivider class="text-background" />

  <section class="container mx-auto py-12">

    <!-- Category filters -->
    <div class="mb-8 flex flex-wrap gap-3">
      <span class="rounded-full bg-primary/10 px-4 py-1.5 text-sm font-medium text-primary">
        {lang === "ar" ? "الكل" : "All"} ({allArticles.length})
      </span>
      {categories.map((cat) => {
        const count = allArticles.filter((a) => a.data.category === cat).length;
        if (count === 0) return null;
        return (
          <span class="rounded-full border border-gray-200 px-4 py-1.5 text-sm text-muted hover:border-primary hover:text-primary cursor-default transition-colors">
            {strings.news.category[cat]} ({count})
          </span>
        );
      })}
    </div>

    <!-- Articles grid -->
    {allArticles.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {allArticles.map((item) => (
          <CardNews
            item={item}
            lang={lang}
            categoryLabel={strings.news.category[item.data.category]}
            readLabel={strings.links.readMore}
            basePath="articles"
          />
        ))}
      </div>
    ) : (
      <div class="rounded-2xl bg-surface py-20 text-center shadow-soft">
        <p class="text-muted">{lang === "ar" ? "لا توجد مقالات بعد." : "No articles yet."}</p>
      </div>
    )}
  </section>

  <TheFooter lang={lang} strings={strings} />
</BaseLayout>
