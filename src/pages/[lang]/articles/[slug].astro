---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import TheFooter from '../../../components/layout/TheFooter.astro';
import WaveDivider from '../../../components/layout/WaveDivider.astro';
import { getCollection } from 'astro:content';
import { getStrings } from '../../../i18n';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const langs = ['ar', 'en'];
  return articles.flatMap((article) =>
    langs.map((lang) => ({
      params: { lang, slug: article.id },
      props: { article },
    }))
  );
}

const { lang } = Astro.params;
const { article } = Astro.props;
const strings = getStrings(lang);

const title = lang === 'ar' ? article.data.titleAr : article.data.title;

const categoryColors: Record<string, string> = {
  'hospital-news': 'bg-primary/10 text-primary',
  'health-tips': 'bg-secondary/10 text-secondary',
  'research': 'bg-accent/10 text-accent',
  'events': 'bg-blue-500/10 text-blue-500',
};

const categoryLabels: Record<string, { en: string; ar: string }> = {
  'hospital-news': { en: 'Hospital News', ar: 'أخبار المستشفى' },
  'health-tips': { en: 'Health Tips', ar: 'نصائح صحية' },
  'research': { en: 'Research', ar: 'الأبحاث' },
  'events': { en: 'Events', ar: 'الفعاليات' },
};

const formatDate = (dateStr: string | Date) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const categoryLabel = categoryLabels[article.data.category]?.[lang === 'ar' ? 'ar' : 'en'] || '';

const breadcrumbs = [
  { label: strings.breadcrumb.home, href: `/${lang}/` },
  { label: lang === 'ar' ? 'المقالات' : 'Articles', href: `/${lang}/articles` },
  { label: title },
];
---

<BaseLayout
  lang={lang}
  strings={strings}
  breadcrumbs={breadcrumbs}
  currentPath={`/${lang}/articles/${article.id}`}
  title={`${title} | ${strings.site.name}`}
  description={title}
>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={`/${lang}/articles/${article.id}`}>
    <!-- Hero banner -->
    <section class="bg-gradient-to-br from-primary/90 to-secondary/90 text-white section-stripes py-16">
      <div class="container mx-auto px-4">
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ${categoryColors[article.data.category] || 'bg-muted/10 text-muted'}`}>
              {categoryLabel}
            </span>
            <time class="text-sm text-white/70">{formatDate(article.data.date)}</time>
            {article.data.author && (
              <>
                <span class="text-white/40">·</span>
                <span class="text-sm text-white/70">{article.data.author}</span>
              </>
            )}
          </div>
          <h1 class="text-4xl font-extrabold leading-tight">{title}</h1>
        </div>
      </div>
    </section>

    <WaveDivider class="text-background" />

    <!-- Main content -->
    <section class="container mx-auto px-4 py-12">
      <div class="grid gap-8 lg:grid-cols-3">
        <!-- Main column -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Thumbnail -->
          {article.data.thumbnail && (
            <div class="rounded-2xl overflow-hidden shadow-soft">
              <img
                src={article.data.thumbnail}
                alt={title}
                class="w-full h-96 object-cover"
              />
            </div>
          )}

          <!-- Article body -->
          {article.data.body && (
            <div class="rounded-2xl bg-surface p-8 shadow-soft">
              <div class="prose prose-sm dark:prose-invert max-w-none text-muted">
                <p>{article.data.body}</p>
              </div>
            </div>
          )}

          <!-- Back link -->
          <div>
            <a
              href={`/${lang}/articles`}
              class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              {lang === 'ar' ? 'العودة إلى المقالات' : 'Back to Articles'}
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Article info card -->
          <div class="rounded-2xl bg-primary p-8 text-white shadow-deep">
            <h3 class="text-lg font-bold mb-4">
              {lang === 'ar' ? 'معلومات المقالة' : 'Article Info'}
            </h3>

            <div class="space-y-4">
              <div>
                <p class="text-xs text-white/60">{lang === 'ar' ? 'التاريخ' : 'Published'}</p>
                <p class="mt-1 font-semibold">{formatDate(article.data.date)}</p>
              </div>

              {article.data.author && (
                <div>
                  <p class="text-xs text-white/60">{lang === 'ar' ? 'الكاتب' : 'Author'}</p>
                  <p class="mt-1 font-semibold">{article.data.author}</p>
                </div>
              )}

              <div>
                <p class="text-xs text-white/60">{lang === 'ar' ? 'النوع' : 'Category'}</p>
                <p class="mt-1 font-semibold">{categoryLabel}</p>
              </div>
            </div>

            <a
              href={`/${lang}/contact`}
              class="mt-6 flex items-center justify-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-primary shadow-soft transition-transform hover:-translate-y-0.5"
            >
              {lang === 'ar' ? 'اتصل بنا' : 'Contact Us'}
            </a>
          </div>

          <!-- Emergency contact -->
          <div class="rounded-2xl bg-surface p-6 shadow-soft text-sm text-muted">
            <p class="font-semibold text-text mb-2">{lang === 'ar' ? 'خط الطوارئ' : 'Emergency Line'}</p>
            <a href="tel:12345" class="text-2xl font-extrabold text-red-600 hover:underline">12345</a>
            <p class="mt-1 text-xs text-muted/70">{lang === 'ar' ? 'متاح على مدار الساعة' : 'Available 24/7'}</p>
          </div>
        </div>
      </div>
    </section>

    <TheFooter lang={lang} strings={strings} />
  </SidebarLayout>
</BaseLayout>
