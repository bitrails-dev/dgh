---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TheNavbar from "../../components/layout/TheNavbar.vue";
import TheFooter from "../../components/layout/TheFooter.astro";
import WaveDivider from "../../components/layout/WaveDivider.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import MissionStrip from "../../components/sections/MissionStrip.astro";
import AchievementsSection from "../../components/sections/AchievementsSection.astro";
import DepartmentsSection from "../../components/sections/DepartmentsSection.astro";
import TeamSection from "../../components/sections/TeamSection.astro";
import TestimonialsSection from "../../components/sections/TestimonialsSection.vue";
import NewsSection from "../../components/sections/NewsSection.astro";
import ContactSection from "../../components/sections/ContactSection.vue";
import { getStrings } from "../../i18n";

export const getStaticPaths = () => [
  { params: { lang: "ar" } },
  { params: { lang: "en" } },
];

const { lang } = Astro.params;
const strings = getStrings(lang);
---
<BaseLayout lang={lang} title={strings.site.name} description={strings.site.description}>
  <TheNavbar lang={lang} strings={strings} isHome client:load />
  <HeroSection lang={lang} strings={strings} />
  <WaveDivider class="text-background" />
  <MissionStrip strings={strings} />
  <AchievementsSection lang={lang} strings={strings} />
  <DepartmentsSection lang={lang} strings={strings} />
  <TeamSection lang={lang} strings={strings} />
  <TestimonialsSection strings={strings} items={strings.testimonials.items} client:visible />
  <NewsSection lang={lang} strings={strings} />
  <ContactSection strings={strings} lang={lang} client:visible />
  <TheFooter lang={lang} strings={strings} />
</BaseLayout>
