---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import PageHeader from '../../../components/ui/PageHeader.astro';
import CardDoctor from '../../../components/ui/CardDoctor.astro';
import { getCollection } from 'astro:content';
import { getStrings } from '../../../i18n';
import type { Locale } from '../../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'ar' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Locale;
const strings = getStrings(lang);
const breadcrumbs = [
  { label: strings.breadcrumb.home, href: `/${lang}/` },
  { label: strings.breadcrumb.team },
];

const doctors = await getCollection('doctors');
const sortByOrder = (a: any, b: any) => (a.data.order ?? 999) - (b.data.order ?? 999);
const featured = doctors.filter((d) => d.data.featured).sort(sortByOrder);
const others = doctors.filter((d) => !d.data.featured).sort(sortByOrder);
---
<BaseLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={`/${lang}/team`} title={`${strings.team.title} | ${strings.site.name}`} description={strings.team.subtitle}>
  <SidebarLayout lang={lang} strings={strings} breadcrumbs={breadcrumbs} currentPath={`/${lang}/team`}>
    <div class="px-6 py-8">
      <PageHeader title={strings.team.title} subtitle={strings.team.subtitle} />

  {featured.length > 0 && (
    <section class="mb-12">
      <h2 class="mb-6 text-lg font-bold text-text">{strings.team.featuredTitle}</h2>
      <div class="grid gap-6 lg:grid-cols-3">
        {featured.map((doctor) => {
          const name = lang === 'ar' ? doctor.data.nameAr : doctor.data.name;
          const specialty = lang === 'ar' ? doctor.data.specialtyAr : doctor.data.specialty;
          const bio = lang === 'ar' ? doctor.data.bioAr : doctor.data.bio;
          return (
            <article class="group overflow-hidden rounded-2xl bg-surface shadow-layered transition-all duration-300 hover:-translate-y-1 hover:shadow-deep">
              <div class="relative overflow-hidden">
                <img src={doctor.data.photo} alt={name} width="400" height="240" class="h-60 w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                {doctor.data.certified && (
                  <span class="absolute top-3 end-3 inline-flex items-center gap-1 rounded-full bg-accent/90 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                    <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-white" aria-hidden="true"><path d="M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z"/></svg>
                    {strings.team.certified}
                  </span>
                )}
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-text">{name}</h3>
                <p class="mt-1 text-sm font-medium text-secondary">{specialty}</p>
                <p class="mt-3 text-sm text-muted line-clamp-3">{bio}</p>
                <a href={`/${lang}/doctors/${doctor.id}`} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:gap-3 transition-all">
                  {strings.team.profileLabel}
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  )}

  {others.length > 0 && (
    <section>
      <h2 class="mb-6 text-lg font-bold text-text">{strings.team.doctorsTitle}</h2>
      <div class="grid gap-5 md:grid-cols-2">
        {others.map((doctor) => (
          <CardDoctor
            doctor={doctor}
            lang={lang}
            certifiedLabel={strings.team.certified}
            profileLabel={strings.team.profileLabel}
            imageAlt={lang === 'ar' ? doctor.data.nameAr : doctor.data.name}
          />
        ))}
      </div>
    </section>
  )}
    </div>
  </SidebarLayout>
</BaseLayout>
