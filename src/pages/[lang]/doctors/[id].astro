---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import { getCollection } from 'astro:content';
import { getStrings } from '../../../i18n';

export const getStaticPaths = async () => {
  const entries = await getCollection('doctors');
  const langs = ['ar', 'en'];
  return entries.flatMap((entry) =>
    langs.map((lang) => ({
      params: { lang, id: entry.id },
      props: { entry },
    }))
  );
};

const { lang } = Astro.params;
const { entry } = Astro.props;
const strings = getStrings(lang);
const name = lang === 'ar' ? entry.data.nameAr : entry.data.name;
const specialty = lang === 'ar' ? entry.data.specialtyAr : entry.data.specialty;
const bio = lang === 'ar' ? entry.data.bioAr : entry.data.bio;
const basePath = `/${lang}`;
---
<BaseLayout
  lang={lang}
  strings={strings}
  title={`${name} — ${strings.site.name}`}
  description={bio}
  ogImage={entry.data.photo}
  breadcrumbs={[{ label: strings.breadcrumb.home, href: `/${lang}/` }, { label: strings.breadcrumb.team, href: `/${lang}/team` }, { label: name }]}
  currentPath={`/${lang}/doctors/${entry.id}`}
>
<SidebarLayout
  lang={lang}
  strings={strings}
  breadcrumbs={[{ label: strings.breadcrumb.home, href: `/${lang}/` }, { label: strings.breadcrumb.team, href: `/${lang}/team` }, { label: name }]}
  currentPath={`/${lang}/doctors/${entry.id}`}
>
  <!-- Page header -->
  <section class="mx-auto max-w-[1440px] px-6 pt-12 pb-2" data-animate="fade">
    <div class="inline-flex items-center gap-2.5 mb-5">
      <div class="w-8 h-px bg-teal-600"></div>
      <p class="h-eyebrow">{strings.nav.team}</p>
    </div>
    <h1 class="font-display-ar font-medium text-navy-900 leading-none tracking-tight" style="font-size: clamp(36px, 4vw, 56px); line-height: 1.1;">{name}</h1>
    <p class="mt-3 text-body-lg text-ink-500">{specialty}</p>
    {entry.data.certified && (
      <span class="mt-4 inline-flex items-center gap-1.5 rounded-full bg-gold/15 px-3 py-1 text-xs font-semibold text-gold">
        <span aria-hidden="true">★</span>
        {strings.team.certified}
      </span>
    )}
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-[1440px] px-6 py-10">
    <div class="grid gap-10 lg:grid-cols-3">

      <!-- Photo + quick contact -->
      <div class="space-y-6" data-animate="fade">
        <div class="overflow-hidden border border-ink-100">
          <img
            src={entry.data.photo}
            alt={name}
            width="400"
            height="480"
            class="h-80 w-full object-cover lg:h-96"
            loading="lazy"
          />
        </div>

        <!-- Appointment CTA -->
        <div class="bg-teal-800 p-6 text-ivory-50 shadow-deep">
          <h3 class="text-base font-bold font-display-ar">{lang === 'ar' ? 'احجز موعداً' : 'Book an Appointment'}</h3>
          <p class="mt-1 text-xs text-ivory-100/70">
            {lang === 'ar' ? 'تواصل مع المستشفى لحجز موعد مع الدكتور' : 'Contact the hospital to schedule an appointment'}
          </p>
          <a href={`/${lang}/contact`} class="btn btn-teal mt-4 w-full justify-center">
            {lang === 'ar' ? 'تواصل معنا' : 'Contact Us'}
          </a>
        </div>

        <div class="bg-ivory-50 p-5 border border-ink-100 text-sm text-ink-500">
          <p class="font-semibold text-ink-900 mb-1">{lang === 'ar' ? 'خط الطوارئ' : 'Emergency Line'}</p>
          <a href="tel:12345" class="text-xl font-extrabold text-coral hover:underline">12345</a>
          <p class="mt-1 text-xs text-ink-400">{lang === 'ar' ? 'متاح على مدار الساعة' : 'Available 24/7'}</p>
        </div>
      </div>

      <!-- Bio + details -->
      <div class="lg:col-span-2 space-y-6" data-animate="fade">
        <div class="bg-ivory-50 p-8 border border-ink-100">
          <h2 class="mb-4 text-lg font-bold text-ink-900 font-display-ar">
            {lang === 'ar' ? 'نبذة تعريفية' : 'About'}
          </h2>
          <p class="text-sm leading-relaxed text-ink-500">{bio}</p>
        </div>

        <div class="bg-ivory-50 p-8 border border-ink-100">
          <h2 class="mb-4 text-lg font-bold text-ink-900 font-display-ar">
            {lang === 'ar' ? 'التخصص والكفاءة' : 'Specialty & Expertise'}
          </h2>
          <div class="flex flex-wrap gap-3">
            <span class="rounded-full bg-teal-700/10 px-4 py-1.5 text-sm font-medium text-teal-700">{specialty}</span>
            {entry.data.certified && (
              <span class="rounded-full bg-gold/15 px-4 py-1.5 text-sm font-medium text-gold">
                {strings.team.certified}
              </span>
            )}
          </div>
        </div>

        {entry.data.department && (
          <div class="border border-ink-100 bg-ivory-50 p-6">
            <p class="text-sm text-ink-500">
              <span class="font-semibold text-ink-900">{lang === 'ar' ? 'القسم:' : 'Department:'}</span>{' '}
              <a href={`${basePath}/departments/${entry.data.department}`} class="text-teal-700 hover:underline">
                {entry.data.department}
              </a>
            </p>
          </div>
        )}
      </div>

    </div>

    <!-- Back link -->
    <div class="mt-10">
      <a href={`/${lang}/team`} class="btn-text text-sm">
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          {lang === 'ar' ? 'العودة إلى الفريق الطبي' : 'Back to Medical Team'}
        </span>
      </a>
    </div>
  </section>

</SidebarLayout>
</BaseLayout>
