---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TheNavbar from "../../../components/layout/TheNavbar.vue";
import TheFooter from "../../../components/layout/TheFooter.astro";
import { getCollection } from "astro:content";
import { getStrings } from "../../../i18n";

export const getStaticPaths = async () => {
  const entries = await getCollection("doctors");
  const langs = ["ar", "en"];
  return entries.flatMap((entry) =>
    langs.map((lang) => ({
      params: { lang, id: entry.slug },
      props: { entry },
    }))
  );
};

const { lang } = Astro.params;
const { entry } = Astro.props;
const strings = getStrings(lang);
const name = lang === "ar" ? entry.data.nameAr : entry.data.name;
const specialty = lang === "ar" ? entry.data.specialtyAr : entry.data.specialty;
const bio = lang === "ar" ? entry.data.bioAr : entry.data.bio;
---
<BaseLayout lang={lang} title={name} description={bio}>
  <TheNavbar lang={lang} strings={strings} client:load />
  <section class="bg-primary text-white section-stripes py-20">
    <div class="container mx-auto">
      <h1 class="text-3xl font-bold">{name}</h1>
      <p class="mt-2 text-sm text-white/70">{specialty}</p>
    </div>
  </section>
  <section class="container mx-auto py-12">
    <div class="grid gap-8 lg:grid-cols-3">
      <img src={entry.data.photo} alt={name} class="h-80 w-full rounded-2xl object-cover shadow-soft" />
      <div class="lg:col-span-2 rounded-2xl bg-surface p-8 shadow-soft">
        <p class="text-sm text-muted">{bio}</p>
        {entry.data.certified && (
          <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-accent/15 px-3 py-1 text-xs font-semibold text-accent">
            <span>★</span>
            <span>{strings.team.certified}</span>
          </div>
        )}
      </div>
    </div>
  </section>
  <TheFooter lang={lang} strings={strings} />
</BaseLayout>
