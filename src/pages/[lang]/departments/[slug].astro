---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TheNavbar from "../../../components/layout/TheNavbar.vue";
import TheFooter from "../../../components/layout/TheFooter.astro";
import WaveDivider from "../../../components/layout/WaveDivider.astro";
import { getCollection } from "astro:content";
import { getStrings } from "../../../i18n";

export const getStaticPaths = async () => {
  const entries = await getCollection("departments");
  const langs = ["ar", "en"];
  return entries.flatMap((entry) =>
    langs.map((lang) => ({
      params: { lang, slug: entry.id },
      props: { entry },
    }))
  );
};

const { lang } = Astro.params;
const { entry } = Astro.props;
const strings = getStrings(lang);
const title = lang === "ar" ? entry.data.nameAr : entry.data.name;
const description = lang === "ar" ? entry.data.descriptionAr : entry.data.description;
const basePath = `/${lang}`;

const detailPoints = [
  { icon: "🔬", text: strings.departments.detailPoints[0] },
  { icon: "👥", text: strings.departments.detailPoints[1] },
  { icon: "💊", text: strings.departments.detailPoints[2] },
];

const allDoctors = await getCollection("doctors");
const deptDoctors = allDoctors.filter((d) => d.data.department === entry.id);
---
<BaseLayout lang={lang} title={`${title} — ${strings.site.name}`} description={description}>
  <TheNavbar lang={lang} strings={strings} client:load />

  <!-- Hero banner -->
  <section class="bg-primary text-white section-stripes py-20">
    <div class="container mx-auto">
      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="mb-6 flex items-center gap-2 text-xs text-white/60">
        <a href={`${basePath}/`} class="hover:text-accent transition-colors">{strings.site.name}</a>
        <span aria-hidden="true">/</span>
        <a href={`${basePath}/#departments`} class="hover:text-accent transition-colors">{strings.nav.departments}</a>
        <span aria-hidden="true">/</span>
        <span class="text-white/90">{title}</span>
      </nav>

      <div class="flex flex-wrap items-start gap-4">
        <div>
          <h1 class="text-4xl font-extrabold">{title}</h1>
          {entry.data.centerOfExcellence && (
            <span class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-accent/20 px-3 py-1 text-xs font-semibold text-accent">
              <span aria-hidden="true">★</span>
              {strings.departments.centerOfExcellence}
            </span>
          )}
        </div>
      </div>
    </div>
  </section>

  <WaveDivider class="text-background" />

  <!-- Content -->
  <section class="container mx-auto py-12">
    <div class="grid gap-8 lg:grid-cols-3">

      <!-- Main description -->
      <div class="lg:col-span-2 space-y-6">
        <div class="rounded-2xl bg-surface p-8 shadow-soft" data-animate="fade">
          <h2 class="mb-4 text-lg font-bold text-text">{lang === "ar" ? "نبذة عن القسم" : "About the Department"}</h2>
          <p class="text-sm leading-relaxed text-muted">{description}</p>
        </div>

        <!-- Detail points -->
        <div class="rounded-2xl bg-white p-8 shadow-soft" data-animate="fade">
          <h2 class="mb-5 text-lg font-bold text-text">
            {lang === "ar" ? "ما يميّزنا" : "What We Offer"}
          </h2>
          <ul class="space-y-4">
            {detailPoints.map(({ icon, text }) => (
              <li class="flex items-start gap-3 text-sm text-muted">
                <span class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-base" aria-hidden="true">{icon}</span>
                <span>{text}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Sidebar CTA -->
      <div class="space-y-6" data-animate="fade">
        <div class="rounded-2xl bg-primary p-8 text-white shadow-deep">
          <h3 class="text-lg font-bold">
            {lang === "ar" ? "احجز موعدك" : "Book an Appointment"}
          </h3>
          <p class="mt-2 text-sm text-white/70">
            {lang === "ar"
              ? "فريقنا المتخصص متاح لمساعدتك. تواصل معنا الآن لحجز موعدك."
              : "Our specialist team is ready to help. Contact us now to schedule your visit."}
          </p>
          <a
            href={`${basePath}/#contact`}
            class="mt-5 flex items-center justify-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-primary shadow-soft transition-transform hover:-translate-y-0.5"
          >
            {lang === "ar" ? "تواصل معنا" : "Contact Us"}
          </a>
          <a
            href={`${basePath}/#team`}
            class="mt-3 flex items-center justify-center gap-2 rounded-lg border border-white/30 px-5 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-80"
          >
            {lang === "ar" ? "تعرّف على الفريق الطبي" : "Meet Our Doctors"}
          </a>
        </div>

        <div class="rounded-2xl bg-surface p-6 shadow-soft text-sm text-muted">
          <p class="font-semibold text-text mb-2">{lang === "ar" ? "خط الطوارئ" : "Emergency Line"}</p>
          <a href="tel:12345" class="text-2xl font-extrabold text-red-600 hover:underline">12345</a>
          <p class="mt-1 text-xs text-muted/70">{lang === "ar" ? "متاح على مدار الساعة" : "Available 24/7"}</p>
        </div>
      </div>

    </div>

    <!-- Department doctors -->
    {deptDoctors.length > 0 && (
      <div class="mt-10" data-animate="fade">
        <h2 class="mb-6 text-lg font-bold text-text">
          {lang === "ar" ? "أطباء القسم" : "Department Doctors"}
        </h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {deptDoctors.map((doctor) => {
            const name = lang === "ar" ? doctor.data.nameAr : doctor.data.name;
            const specialty = lang === "ar" ? doctor.data.specialtyAr : doctor.data.specialty;
            return (
              <article class="rounded-2xl bg-surface p-5 shadow-soft transition-all hover:shadow-layered">
                <div class="flex items-start gap-4">
                  <img
                    src={doctor.data.photo}
                    alt={name}
                    width="64"
                    height="64"
                    class="h-16 w-16 rounded-full object-cover flex-shrink-0"
                    loading="lazy"
                  />
                  <div>
                    <h3 class="font-bold text-text">{name}</h3>
                    <p class="text-sm text-secondary">{specialty}</p>
                    {doctor.data.certified && (
                      <span class="mt-1 inline-flex items-center gap-1 text-xs text-accent">
                        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-accent" aria-hidden="true">
                          <path d="M12 2l2.9 6.2 6.6.6-5 4.3 1.6 6.4-6.1-3.4-6.1 3.4 1.6-6.4-5-4.3 6.6-.6L12 2z"/>
                        </svg>
                        {strings.team.certified}
                      </span>
                    )}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    )}

    <!-- Back link -->
    <div class="mt-10">
      <a href={`${basePath}/#departments`} class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rtl:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        {lang === "ar" ? "العودة إلى الأقسام" : "Back to Departments"}
      </a>
    </div>
  </section>

  <TheFooter lang={lang} strings={strings} />
</BaseLayout>
