---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TheNavbar from "../../../components/layout/TheNavbar.vue";
import TheFooter from "../../../components/layout/TheFooter.astro";
import { getCollection } from "astro:content";
import { getStrings } from "../../../i18n";

export const getStaticPaths = async () => {
  const entries = await getCollection("departments");
  const langs = ["ar", "en"];
  return entries.flatMap((entry) =>
    langs.map((lang) => ({
      params: { lang, slug: entry.slug },
      props: { entry },
    }))
  );
};

const { lang } = Astro.params;
const { entry } = Astro.props;
const strings = getStrings(lang);
const title = lang === "ar" ? entry.data.nameAr : entry.data.name;
const description = lang === "ar" ? entry.data.descriptionAr : entry.data.description;
---
<BaseLayout lang={lang} title={title} description={description}>
  <TheNavbar lang={lang} strings={strings} client:load />
  <section class="bg-primary text-white section-stripes py-20">
    <div class="container mx-auto">
      <h1 class="text-3xl font-bold">{title}</h1>
      {entry.data.centerOfExcellence && (
        <span class="mt-4 inline-flex rounded-full bg-accent/20 px-3 py-1 text-xs font-semibold text-accent">
          {strings.departments.centerOfExcellence}
        </span>
      )}
    </div>
  </section>
  <section class="container mx-auto py-12">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="lg:col-span-2 rounded-2xl bg-surface p-8 shadow-soft">
        <p class="text-sm text-muted">{description}</p>
      </div>
      <div class="rounded-2xl bg-white p-6 shadow-soft">
        <p class="text-sm font-semibold text-text">{strings.departments.learnMore}</p>
        <ul class="mt-4 space-y-2 text-sm text-muted">
          {strings.departments.detailPoints.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>
  <TheFooter lang={lang} strings={strings} />
</BaseLayout>
