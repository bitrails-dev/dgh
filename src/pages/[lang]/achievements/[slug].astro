---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TheNavbar from "../../../components/layout/TheNavbar.vue";
import TheFooter from "../../../components/layout/TheFooter.astro";
import { getCollection } from "astro:content";
import { getStrings } from "../../../i18n";

export const getStaticPaths = async () => {
  const entries = await getCollection("achievements");
  const langs = ["ar", "en"];
  return entries.flatMap((entry) =>
    langs.map((lang) => ({
      params: { lang, slug: entry.slug },
      props: { entry },
    }))
  );
};

const { lang } = Astro.params;
const { entry } = Astro.props;
const strings = getStrings(lang);
const title = lang === "ar" ? entry.data.titleAr : entry.data.title;
const description = lang === "ar" ? entry.data.descriptionAr : entry.data.description;
---
<BaseLayout lang={lang} title={title} description={description}>
  <TheNavbar lang={lang} strings={strings} client:load />
  <section class="bg-primary text-white section-stripes py-20">
    <div class="container mx-auto">
      <span class="inline-flex rounded-full bg-accent/20 px-3 py-1 text-xs font-semibold text-accent">
        {entry.data.year}
      </span>
      <h1 class="mt-4 text-3xl font-bold">{title}</h1>
    </div>
  </section>
  <section class="container mx-auto py-12">
    <div class="rounded-2xl bg-surface p-8 shadow-soft">
      <p class="text-sm text-muted">{description}</p>
    </div>
  </section>
  <TheFooter lang={lang} strings={strings} />
</BaseLayout>
