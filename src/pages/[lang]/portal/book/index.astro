---
import PortalLayout from "../../../../layouts/PortalLayout.astro";
import PortalBook from "../../../../components/portal/PortalBook.vue";
import { getStrings } from "../../../../i18n";

export const getStaticPaths = () => [
  { params: { lang: "ar" } },
  { params: { lang: "en" } },
];

const { lang } = Astro.params;
const strings = getStrings(lang);
---
<PortalLayout
  lang={lang}
  strings={strings}
  title={`${strings.portal.book.title} | ${strings.site.name}`}
  description={strings.portal.book.description}
>
  <PortalBook lang={lang} strings={strings} client:load />
</PortalLayout>
