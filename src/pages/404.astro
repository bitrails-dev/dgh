---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getStrings } from "../i18n";

const ar = getStrings("ar");
const en = getStrings("en");
---
<BaseLayout lang="ar" strings={ar} title={ar.notFound.title} description={ar.notFound.body} noindex={true}>
  <section class="min-h-screen bg-background flex items-center">
    <div class="container mx-auto py-20">
      <div class="mx-auto max-w-2xl text-center">

        <!-- 404 visual -->
        <div class="relative mb-8 inline-block">
          <span class="text-[10rem] font-extrabold leading-none text-primary/10 select-none">404</span>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-primary shadow-deep">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- Arabic content -->
        <div class="rounded-2xl bg-surface p-10 shadow-soft" dir="rtl">
          <h1 class="text-3xl font-extrabold text-text">{ar.notFound.title}</h1>
          <p class="mt-3 text-sm text-muted">{ar.notFound.body}</p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href="/ar" class="rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white shadow-soft transition-transform hover:-translate-y-0.5">
              {ar.notFound.cta}
            </a>
            <a href="/ar/#contact" class="rounded-lg border border-primary px-6 py-3 text-sm font-semibold text-primary transition-opacity hover:opacity-70">
              {ar.nav.contact}
            </a>
          </div>
        </div>

        <!-- English content -->
        <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-8 shadow-soft" dir="ltr">
          <h2 class="text-xl font-bold text-text">{en.notFound.title}</h2>
          <p class="mt-2 text-sm text-muted">{en.notFound.body}</p>
          <div class="mt-4 flex flex-wrap justify-center gap-3">
            <a href="/en" class="rounded-lg border border-primary px-5 py-2.5 text-sm font-semibold text-primary transition-opacity hover:opacity-70">
              {en.notFound.cta}
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
