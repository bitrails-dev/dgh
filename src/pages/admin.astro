---
import DashboardApp from '../components/dashboard/DashboardApp.vue';
import '../styles/global.css';
---
<!doctype html>
<html lang="ar" dir="rtl" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>لوحة التحكم — مستشفى دمياط العام</title>
  </head>
  <body class="h-full overflow-hidden bg-gray-100">
    <DashboardApp client:only="vue" />
  </body>
</html>

<style is:global>
  /* Make the Astro island wrapper transparent to layout so h-full chains correctly */
  body > astro-island {
    display: contents;
  }
</style>
