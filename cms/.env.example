# Payload secret — any long random string. Generate: openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Local libSQL (no cloud). Two options:
#   1. Embedded file (simplest, no server):   file:./cms.db
#   2. Local libSQL server via `turso dev`:    http://127.0.0.1:8080
DATABASE_URI=file:./cms.db

# Not needed for local file or `turso dev`. Leave empty.
DATABASE_AUTH_TOKEN=

# Used for CORS/CSRF.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# Social auto-publishing (see docs/superpowers/SETUP-social-publishing.md)
# Every var below is OPTIONAL. A platform whose vars are blank is simply skipped
# (recorded as "skipped: not configured"), so the CMS runs fine with none set.
# ─────────────────────────────────────────────────────────────────────────────

# Public origin of the Astro site — used to build the article link attached to posts.
SITE_URL=https://dgh.bitrail.dev
# Public origin that serves /uploads/videos/* so pull-from-URL APIs (Facebook,
# TikTok, Instagram) can fetch the file. Must be publicly reachable in production.
PUBLIC_MEDIA_BASE=https://dgh.bitrail.dev

# Facebook Page — link + native video posts. Needs a long-lived Page access token.
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_API_VERSION=v21.0

# YouTube Data API v3 — resumable video upload (OAuth refresh-token flow).
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
YT_PRIVACY=public
YT_CATEGORY_ID=22

# TikTok Content Posting API — Direct Post, pull-from-URL. Unaudited apps: SELF_ONLY.
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY=SELF_ONLY

# Instagram Reels — IG Business account linked to a Facebook Page (shares FB token).
IG_USER_ID=
IG_ACCESS_TOKEN=

# LinkedIn — article link share. Author URN: urn:li:organization:<id> or urn:li:person:<id>.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# Override where uploaded videos live on disk (default: ../public/uploads/videos).
# MEDIA_VIDEOS_DIR=
