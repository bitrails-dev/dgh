# Payload secret — any long random string. Generate: openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Local libSQL (no cloud). Two options:
#   1. Embedded file (simplest, no server):   file:./cms.db
#   2. Local libSQL server via `turso dev`:    http://127.0.0.1:8080
DATABASE_URI=file:./cms.db

# Not needed for local file or `turso dev`. Leave empty.
DATABASE_AUTH_TOKEN=

# Used for CORS/CSRF.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
