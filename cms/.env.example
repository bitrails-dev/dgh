# Payload secret — any long random string. Generate: openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Local libSQL (no cloud). Two options:
#   1. Embedded file (simplest, no server):   file:./cms.db
#   2. Local libSQL server via `turso dev`:    http://127.0.0.1:8080
DATABASE_URI=file:./cms.db

# Not needed for local file or `turso dev`. Leave empty.
DATABASE_AUTH_TOKEN=

# Used for CORS/CSRF.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# --- Social auto-publishing (Tier-1: Facebook, Instagram, LinkedIn, YouTube) ---
# Derives the AES-256-GCM token key + HMAC OAuth-state key (versioned). Never put real secrets in
# source; these are read from the deployed environment.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public, internet-reachable base URLs used to build canonical article links + image URLs + OAuth
# redirect URIs. All three must resolve from the open internet (providers fetch image URLs).
SOCIAL_SITE_URL=https://dgh.bitrail.dev
SOCIAL_MEDIA_BASE=https://cms.dgh.bitrail.dev
# OAuth redirect base. Register `${SOCIAL_REDIRECT_BASE}/api/social/callback/<platform>` per provider.
SOCIAL_REDIRECT_BASE=https://cms.dgh.bitrail.dev

# Facebook (Page) — Meta app client id/secret with the OAuth redirect + pages_manage_posts scope.
SOCIAL_FB_CLIENT_ID=
SOCIAL_FB_CLIENT_SECRET=

# Instagram (professional account linked to a FB Page) — separate or shared Meta app.
SOCIAL_IG_CLIENT_ID=
SOCIAL_IG_CLIENT_SECRET=

# LinkedIn (member share) — LinkedIn Developers app with the w_member_social scope.
SOCIAL_LINKEDIN_CLIENT_ID=
SOCIAL_LINKEDIN_CLIENT_SECRET=

# YouTube — Google Cloud OAuth client (youtube.upload). Publishes only owned video; until the
# Article model supports owned uploads, every YouTube publication is `skipped: no_owned_video`.
SOCIAL_YOUTUBE_CLIENT_ID=
SOCIAL_YOUTUBE_CLIENT_SECRET=

# X (Twitter) API v2 — OAuth 2.0 PKCE. Pay-per-use API (free tier closed Feb 2026); posts are billed.
SOCIAL_X_CLIENT_ID=
SOCIAL_X_CLIENT_SECRET=

# Threads API (GA) — App Review required for the threads_content_publish scope.
SOCIAL_THREADS_CLIENT_ID=
SOCIAL_THREADS_CLIENT_SECRET=

# TikTok Content Posting API — needs domain verification + app audit for DIRECT_POST.
SOCIAL_TIKTOK_CLIENT_ID=
SOCIAL_TIKTOK_CLIENT_SECRET=

# --- Commerce gateway (signed storefront->CMS requests, plan §4.1) ---
# HMAC-SHA256 gateway signing. The CMS VERIFIES (current + optional previous, for key rotation);
# Astro signs with the current key only. The secret is base64 of >=32 random bytes
# (`openssl rand -base64 48`). Must NOT reuse PAYLOAD_SECRET or any provider secret. Remove the
# previous pair after every Astro instance has switched to the current key.
COMMERCE_GATEWAY_KEY_ID=
COMMERCE_GATEWAY_SECRET=
COMMERCE_GATEWAY_PREVIOUS_KEY_ID=
COMMERCE_GATEWAY_PREVIOUS_SECRET=

# --- Gift-card pepper (plan §3.10) ---
# Gift-card codes are looked up as HMAC-SHA256(COMMERCE_GIFT_CARD_PEPPER, normalizedRawCode); the
# raw code is shown once at issuance and never stored. Base64 of >=32 random bytes. Must NOT reuse
# PAYLOAD_SECRET, the gateway secret, or any provider secret.
COMMERCE_GIFT_CARD_PEPPER=
