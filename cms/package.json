{
  "name": "codex-cms",
  "version": "1.0.0",
  "description": "Payload CMS for the hospital site. Authors content, exports markdown to ../src/content for Astro.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "export": "tsx scripts/export-to-content.ts",
    "import": "tsx scripts/import-from-content.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@payloadcms/db-sqlite": "latest",
    "@payloadcms/next": "latest",
    "@payloadcms/richtext-lexical": "latest",
    "dotenv": "^16.4.7",
    "graphql": "^16.9.0",
    "gray-matter": "^4.0.3",
    "next": "~15.4.11",
    "payload": "latest",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "autoprefixer": "^10.5.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
